<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>medi360 CRM</title>
<!-- Security cleaned: no service_role key in frontend. Version: safe-frontend-2026-04-28 -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#2B3BF0;--blue-soft:#eef0fe;--navy:#1a1f3a;
  --white:#fff;--surface:#f6f8fc;--surface-2:#edf1f7;
  --border:rgba(26,31,58,0.1);--border-2:rgba(26,31,58,0.06);
  --green:#10b981;--green-soft:#E1F5EE;--green-dark:#0F6E56;
  --amber-soft:#FAEEDA;--amber-dark:#854F0B;
  --red:#ef4444;--red-soft:#FCEBEB;--red-dark:#A32D2D;
  --purple-soft:#EEEDFE;--purple-dark:#3C3489;
  --blue-2-soft:#E6F1FB;--blue-2-dark:#185FA5;
  --text:#1a1f3a;--text-2:#5b6380;--text-3:#9aa0b8;
  --shadow-sm:0 1px 3px rgba(26,31,58,0.06);
  --shadow:0 4px 16px rgba(26,31,58,0.1);
  --shadow-lg:0 16px 48px rgba(26,31,58,0.15);
  --font:'DM Sans',system-ui,sans-serif;--mono:'DM Mono',monospace;
}
html{font-size:14px}
body{font-family:var(--font);background:var(--surface);color:var(--text);-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px}
input,select,textarea{font-family:var(--font);font-size:13px;color:var(--text);background:var(--white);border:1px solid var(--border);border-radius:8px;padding:8px 11px;outline:none;transition:.15s}
input:focus,select:focus,textarea:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(43,59,240,0.08)}
input::placeholder,textarea::placeholder{color:var(--text-3)}
button{font-family:var(--font);cursor:pointer;border:none;transition:.15s}
a{color:inherit;text-decoration:none}

/* LAYOUT */
#app{display:flex;min-height:100vh}
.sidebar{width:220px;background:var(--navy);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;transition:transform .2s}
.sidebar.collapsed{width:60px}
.sidebar-logo{padding:16px;border-bottom:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:space-between;min-height:60px}
.logo-circles{display:flex;align-items:center}
.logo-circles span:first-child{width:14px;height:14px;border-radius:50%;background:rgba(255,255,255,0.35);display:block}
.logo-circles span:last-child{width:14px;height:14px;border-radius:50%;background:var(--blue);margin-left:-5px;display:block}
.logo-text{color:#fff;font-size:15px;font-weight:600;margin-left:8px;letter-spacing:-.3px}
.logo-sub{color:rgba(255,255,255,0.3);font-size:9px;letter-spacing:.5px;display:block}
.collapse-btn{background:none;color:rgba(255,255,255,0.4);padding:4px;border-radius:4px;font-size:16px;line-height:1}
.collapse-btn:hover{color:rgba(255,255,255,0.7)}

.clinic-picker{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,0.08)}
.clinic-picker-btn{width:100%;display:flex;align-items:center;justify-content:space-between;background:rgba(43,59,240,0.25);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:7px 10px;cursor:pointer;color:#fff;font-size:11px;font-family:var(--font)}
.clinic-dropdown{position:absolute;top:100%;left:12px;right:12px;background:var(--white);border-radius:8px;border:1px solid var(--border);z-index:200;box-shadow:var(--shadow-lg);max-height:200px;overflow-y:auto}
.clinic-option{padding:10px 12px;font-size:12px;cursor:pointer;color:var(--text)}
.clinic-option:hover{background:var(--surface)}
.clinic-option.selected{background:var(--blue-soft);color:var(--blue);font-weight:500}

.sidebar-nav{flex:1;padding:8px 0;overflow-y:auto}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 16px;font-size:13px;color:rgba(255,255,255,0.55);cursor:pointer;border-left:3px solid transparent;min-height:44px;transition:all .12s;user-select:none}
.nav-item:hover{color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.05)}
.nav-item.active{color:#fff;background:rgba(43,59,240,0.3);border-left-color:var(--blue);font-weight:500}
.nav-icon{font-size:15px;flex-shrink:0;width:16px;text-align:center}
.nav-label{}
.sidebar.collapsed .nav-label{display:none}
.sidebar.collapsed .nav-item{justify-content:center;padding:10px 0}
.sidebar.collapsed .clinic-picker{display:none}
.sidebar.collapsed .logo-text,.sidebar.collapsed .logo-sub{display:none}

.sidebar-footer{padding:12px 16px;border-top:1px solid rgba(255,255,255,0.08)}
.sidebar.collapsed .sidebar-footer{padding:12px 0;display:flex;justify-content:center}
.user-info{display:flex;align-items:center;gap:8px}
.user-avatar{width:30px;height:30px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;flex-shrink:0}
.user-name{color:rgba(255,255,255,0.85);font-size:12px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.user-role{color:rgba(255,255,255,0.35);font-size:9px;text-transform:uppercase;letter-spacing:.5px}
.logout-btn{background:none;color:rgba(255,255,255,0.3);font-size:16px;padding:4px;margin-left:auto}
.logout-btn:hover{color:rgba(255,255,255,0.7)}

.main{margin-left:220px;flex:1;display:flex;flex-direction:column;min-height:100vh;transition:margin-left .2s}
.main.expanded{margin-left:60px}
.topbar{height:56px;background:var(--white);border-bottom:1px solid var(--border-2);display:flex;align-items:center;padding:0 24px;gap:12px;position:sticky;top:0;z-index:50}
.topbar-title{font-size:15px;font-weight:500;flex:1}
.hamburger{display:none;flex-direction:column;gap:4px;padding:8px;background:none;border-radius:6px}
.hamburger span{width:18px;height:2px;background:var(--navy);border-radius:99px;display:block}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:99}

.page{padding:24px;animation:pageIn .2s ease}
@keyframes pageIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.page-header{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px}
.page-title{font-size:20px;font-weight:600;color:var(--navy);letter-spacing:-.4px}
.page-sub{font-size:12px;color:var(--text-2);margin-top:3px}

/* CARD */
.card{background:var(--white);border-radius:12px;border:1px solid var(--border-2);box-shadow:var(--shadow-sm);overflow:hidden}
.card-header{padding:14px 18px;border-bottom:1px solid var(--border-2);display:flex;align-items:center;justify-content:space-between}
.card-title{font-size:13px;font-weight:600}

/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.stat-card{background:var(--white);border-radius:12px;border:1px solid var(--border-2);padding:18px;box-shadow:var(--shadow-sm);transition:.15s}
.stat-card:hover{box-shadow:var(--shadow);transform:translateY(-1px)}
.stat-label{font-size:11px;font-weight:500;color:var(--text-2);text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px}
.stat-value{font-size:28px;font-weight:600;letter-spacing:-1px;line-height:1;margin-bottom:6px}
.stat-change{font-size:11px;color:var(--text-3)}
.stat-change.up{color:var(--green)}
.stat-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;margin-bottom:10px}

/* TABLE */
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
thead tr{background:var(--surface)}
th{padding:9px 14px;text-align:left;font-size:10.5px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:.6px;white-space:nowrap}
td{padding:12px 14px;font-size:13px;border-top:1px solid var(--border-2)}
tr:hover td{background:var(--surface)}
tr{cursor:pointer}

/* BADGE */
.badge{display:inline-flex;align-items:center;font-size:11px;font-weight:500;padding:2px 8px;border-radius:99px;white-space:nowrap}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:8px;font-size:13px;font-weight:500;line-height:1;white-space:nowrap;transition:.15s}
.btn-primary{background:var(--blue);color:#fff}
.btn-primary:hover{background:#1e2cb8;box-shadow:0 4px 12px rgba(43,59,240,0.3)}
.btn-ghost{background:transparent;color:var(--text-2);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--surface);color:var(--text)}
.btn-sm{padding:5px 11px;font-size:12px}
.btn-xs{padding:3px 8px;font-size:11px;border-radius:6px}
.btn-danger{background:var(--red-soft);color:var(--red-dark)}

/* SEARCH */
.search-box{display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:7px 12px}
.search-box input{border:none;background:transparent;font-size:12px;outline:none;width:100%;color:var(--text)}

/* FILTER TABS */
.filter-tabs{display:flex;gap:6px;flex-wrap:wrap}
.filter-tab{font-size:11px;padding:4px 10px;border-radius:6px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text-2);font-family:var(--font)}
.filter-tab.active{background:var(--blue);color:#fff;border-color:var(--blue)}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(10,12,24,0.5);backdrop-filter:blur(3px);z-index:300;display:flex;align-items:center;justify-content:center;padding:16px;animation:fadeIn .15s}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal{background:var(--white);border-radius:16px;box-shadow:var(--shadow-lg);width:100%;max-width:460px;animation:slideUp .2s cubic-bezier(.34,1.56,.64,1);max-height:90vh;overflow-y:auto}
@keyframes slideUp{from{opacity:0;transform:translateY(20px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.modal-header{padding:20px 22px 0;display:flex;align-items:center;justify-content:space-between}
.modal-title{font-size:15px;font-weight:600}
.modal-close{width:26px;height:26px;border-radius:50%;background:var(--surface-2);color:var(--text-2);display:flex;align-items:center;justify-content:center;font-size:16px}
.modal-close:hover{background:var(--surface)}
.modal-body{padding:18px 22px}
.modal-footer{padding:0 22px 20px;display:flex;gap:10px;justify-content:flex-end}
.form-group{margin-bottom:14px}
.form-label{display:block;font-size:12px;font-weight:500;color:var(--text-2);margin-bottom:5px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-control{width:100%}

/* APPT CARD */
.appt-card{background:var(--white);border-radius:10px;border:1px solid var(--border-2);padding:14px 16px;display:flex;align-items:center;gap:14px;box-shadow:var(--shadow-sm);transition:.15s}
.appt-card:hover{box-shadow:var(--shadow);transform:translateY(-1px)}

/* LOGIN */
.login-screen{min-height:100vh;display:flex;background:linear-gradient(135deg,#0d1129 0%,#1a1f3a 50%,#0f1628 100%);overflow:hidden;position:relative}
.login-blob{position:absolute;border-radius:50%;filter:blur(60px);pointer-events:none}
.login-wrap{margin:auto;width:100%;max-width:400px;padding:20px;position:relative;z-index:1}
.login-card{background:rgba(255,255,255,0.05);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.1);border-radius:20px;padding:38px 34px}
.login-input{background:rgba(255,255,255,0.07)!important;border:1px solid rgba(255,255,255,0.12)!important;color:#fff!important;margin-bottom:14px}
.login-input::placeholder{color:rgba(255,255,255,0.3)!important}
.login-label{display:block;font-size:12px;font-weight:500;color:rgba(255,255,255,0.5);margin-bottom:5px}

/* EMPTY */
.empty-state{text-align:center;padding:48px 20px;color:var(--text-2)}
.empty-icon{font-size:32px;margin-bottom:10px;opacity:.35}

/* PIPELINE */
.pipeline-col{background:var(--surface);border-radius:10px;padding:12px;min-width:220px;flex:1}
.pipeline-card{background:var(--white);border-radius:8px;border:1px solid var(--border-2);padding:12px;margin-bottom:8px;box-shadow:var(--shadow-sm);cursor:pointer}
.pipeline-card:hover{box-shadow:var(--shadow);transform:translateY(-1px)}

/* RESPONSIVE */
@media(max-width:768px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.mobile-open{transform:translateX(0);box-shadow:var(--shadow-lg)}
  .main,.main.expanded{margin-left:0}
  .hamburger{display:flex}
  .overlay.open{display:block}
  .page{padding:14px}
  .stats-grid{grid-template-columns:1fr 1fr;gap:10px}
  .stat-value{font-size:22px}
  .hide-mobile{display:none}
  .form-row{grid-template-columns:1fr}
  .dash-grid{grid-template-columns:1fr!important}
  th,td{padding:9px 10px}
}
@media(max-width:1100px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>
<div id="app"></div>
<script>
// ── SUPABASE ──
const { createClient } = supabase;
// ── PUBLIC SUPABASE CONFIG ──
// Βάλε ΜΟΝΟ public values εδώ. ΠΟΤΕ service_role / sb_secret key σε frontend αρχείο.
const SUPABASE_URL = 'https://YOUR-PROJECT.supabase.co';
const SUPABASE_ANON = 'YOUR_PUBLIC_ANON_KEY';
const sb = createClient(SUPABASE_URL, SUPABASE_ANON);

// Admin actions (π.χ. create user) πρέπει να γίνονται μέσω Supabase Edge Function
// με service_role key αποθηκευμένο ως server-side secret, όχι μέσα στο HTML.

// ── STATE ──
let S = {
  user: null, profile: null, clinic: null, allClinics: [],
  selectedClinicId: localStorage.getItem('medi360_clinic') || null,
  page: 'login', sidebarOpen: false, sidebarCollapsed: false,
  modal: null, modalData: {},
  patients: [], appointments: [], pipeline: [], clinics: [],
  loading: false, search: '', filter: 'all',
  patientDetail: null,
};

function set(patch) { Object.assign(S, patch); render(); }

// ── HELPERS ──
const esc = s => (s||'').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const initials = n => (n||'').split(' ').map(x=>x[0]).join('').toUpperCase().slice(0,2)||'?';
const fmt = d => d ? new Date(d).toLocaleDateString('el-GR',{day:'2-digit',month:'2-digit',year:'numeric'}) : '—';
const fmtDt = d => d ? new Date(d).toLocaleDateString('el-GR',{weekday:'short',day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) : '—';
const euro = v => '€'+(v||0).toLocaleString('el-GR');

const ROLES = {super_admin:'Super Admin',clinic_admin:'Διαχειριστής',therapist:'Θεραπευτής',receptionist:'Γραμματεία'};
const STATUS_PAT = {active:{bg:'#E1F5EE',c:'#0F6E56',l:'Ενεργός'},vip:{bg:'#EEEDFE',c:'#3C3489',l:'VIP'},lead:{bg:'#E6F1FB',c:'#185FA5',l:'Lead'},inactive:{bg:'#FCEBEB',c:'#A32D2D',l:'Ανενεργός'}};
const STATUS_APPT = {pending:{bg:'#FAEEDA',c:'#854F0B',l:'Εκκρεμεί'},confirmed:{bg:'#E1F5EE',c:'#0F6E56',l:'Επιβεβαιωμένο'},in_progress:{bg:'#E6F1FB',c:'#185FA5',l:'Σε εξέλιξη'},completed:{bg:'#E1F5EE',c:'#0F6E56',l:'Ολοκληρώθηκε'},cancelled:{bg:'#FCEBEB',c:'#A32D2D',l:'Ακυρώθηκε'},no_show:{bg:'#FCEBEB',c:'#A32D2D',l:'No Show'},paid:{bg:'#E1F5EE',c:'#0F6E56',l:'Πληρωμένο'}};
const PIPELINE_STAGES = ['new_lead','contacted','interested','offer_sent','won','lost'];
const STAGE_LABELS = {new_lead:'Νέο Lead',contacted:'Επαφή',interested:'Ενδιαφέρον',offer_sent:'Προσφορά',won:'✓ Κλείσιμο',lost:'✗ Απώλεια'};

function badge(label,bg,c){return `<span class="badge" style="background:${bg};color:${c}">${esc(label)}</span>`}
function patBadge(status){const s=STATUS_PAT[status]||STATUS_PAT.lead;return badge(s.l,s.bg,s.c)}
function apptBadge(status){const s=STATUS_APPT[status]||STATUS_APPT.pending;return badge(s.l,s.bg,s.c)}

// ── AUTH ──
async function init() {
  const { data:{session} } = await sb.auth.getSession();
  if (session&&session.user) await loadProfile(session.user);
  else { set({page:'login',loading:false}); }
  sb.auth.onAuthStateChange((_,session) => {
    if (session&&session.user) loadProfile(session.user);
    else set({user:null,profile:null,clinic:null,allClinics:[],page:'login'});
  });
}

async function loadProfile(user) {
  S.user = user;
  const {data:p} = await sb.from('profiles').select('*').eq('id',user.id).single();
  if (!p) { set({page:'login'}); return; }
  S.profile = p;
  if (p.role === 'super_admin') {
    const {data:c} = await sb.from('clinics').select('*').eq('active',true).order('name');
    S.allClinics = c||[];
    if (S.selectedClinicId) S.clinic = S.allClinics.find(x=>x.id===S.selectedClinicId)||null;
  } else if (p.clinic_id) {
    const {data:c} = await sb.from('clinics').select('*').eq('id',p.clinic_id).single();
    S.clinic = c;
    S.selectedClinicId = p.clinic_id;
  }
  set({page:'dashboard',loading:false});
}

async function login(email,pass) {
  const {data,error} = await sb.auth.signInWithPassword({email,password:pass});
  if (error) throw error;
  return data;
}
async function logout() {
  localStorage.removeItem('medi360_clinic');
  await sb.auth.signOut();
}
function selectClinic(id) {
  S.selectedClinicId = id;
  S.clinic = S.allClinics.find(c=>c.id===id)||null;
  localStorage.setItem('medi360_clinic',id);
  loadPageData();
  render();
}
const isSuperAdmin = () => (S.profile&&S.profile.role) === 'super_admin';
const clinicId = () => S.selectedClinicId;
const canSee = (roles) => roles.includes((S.profile&&S.profile.role));

// ── SECURE SERVER-SIDE ACTIONS ──
async function createUserSecurely({ name, email, password, role, clinic_id }) {
  const { data, error } = await sb.functions.invoke('admin-create-user', {
    body: { full_name: name, email, password, role, clinic_id: clinic_id || null }
  });
  if (error) throw error;
  if (data && data.error) throw new Error(data.error);
  return data;
}

// ── DATA ──
async function loadPageData() {
  const cid = clinicId();
  if (!cid) return;
  if (S.page==='patients' || S.page==='dashboard') {
    const {data} = await sb.from('patients').select('*').eq('clinic_id',cid).order('created_at',{ascending:false});
    S.patients = data||[];
  }
  if (S.page==='appointments' || S.page==='dashboard' || S.page==='calendar') {
    const {data} = await sb.from('appointments').select('*, patients(full_name,phone,status)').eq('clinic_id',cid).order('start_time',{ascending:false}).limit(200);
    S.appointments = data||[];
  }
  if (S.page==='calendar') {
    const {data:staff} = await sb.from('profiles').select('*').eq('clinic_id',cid).in('role',['therapist','clinic_admin','super_admin']);
    S.staff = staff||[];
  }
  if (S.page==='pipeline' || S.page==='dashboard') {
    const {data} = await sb.from('pipeline_leads').select('*').eq('clinic_id',cid).order('created_at',{ascending:false});
    S.pipeline = data||[];
  }
  if (S.page==='clinics' && isSuperAdmin()) {
    const {data} = await sb.from('clinics').select('*').order('name');
    S.clinics = data||[];
  }
  if (S.page==='laser') {
    const {data} = await sb.from('laser_forms').select('*, patients(full_name,phone)').eq('clinic_id',cid).order('created_at',{ascending:false});
    S.laserForms = data||[];
  }
  if (S.page==='laser-detail') {
    if (S.laserFormId) {
      const {data} = await sb.from('laser_forms').select('*, patients(full_name,phone,gender)').eq('id',S.laserFormId).single();
      S.laserFormDetail = data||null;
    }
  }
  if (S.page==='sms') {
    const {data:clinicData} = await sb.from('clinics').select('sms_settings').eq('id',cid).single();
    S.smsSettings = (clinicData&&clinicData.sms_settings) || null;
    const {data:log} = await sb.from('sms_log').select('*, patients(full_name)').eq('clinic_id',cid).order('sent_at',{ascending:false}).limit(50);
    S.smsLog = log||[];
  }
  if (S.page==='consents') {
    const {data:gdpr} = await sb.from('gdpr_consents').select('*, patients(full_name,phone)').eq('clinic_id',cid).order('signed_at',{ascending:false});
    S.gdprConsents = gdpr||[];
    const {data:svc} = await sb.from('service_consents').select('*, patients(full_name,phone)').eq('clinic_id',cid).order('signed_at',{ascending:false});
    S.serviceConsents = svc||[];
    const {data:tmpl} = await sb.from('service_consent_templates').select('*').eq('clinic_id',cid).order('created_at',{ascending:false});
    S.consentTemplates = tmpl||[];
  }
  render();
}

async function loadPatientDetail(id) {
  const {data:p} = await sb.from('patients').select('*').eq('id',id).single();
  const {data:a} = await sb.from('appointments').select('*').eq('patient_id',id).order('start_time',{ascending:false}).limit(20);
  const {data:lf} = await sb.from('laser_forms').select('*').eq('patient_id',id).order('created_at',{ascending:false});
  S.patientDetail = {...p, appointments: a||[]};
  S.laserForms = lf||[];
  S.patConsultations = [];
  S.patTab = 'overview';
  set({page:'patient-detail'});
}

// ── RENDER ──
function render() {
  document.getElementById('app').innerHTML =
    !S.user ? renderLogin() :
    S.page==='patient-detail' ? renderShell(renderPatientDetail()) :
    renderShell(
      S.page==='dashboard' ? renderDashboard() :
      S.page==='patients' ? renderPatients() :
      S.page==='appointments' ? renderAppointments() :
      S.page==='calendar' ? renderCalendar() :
      S.page==='pipeline' ? renderPipeline() :
      S.page==='clinics' ? renderClinics() :
      S.page==='laser' ? renderLaserForms() :
      S.page==='laser-detail' ? renderLaserDetail() :
      S.page==='sms' ? renderSms() :
      S.page==='consents' ? renderConsents() :
      S.page==='settings' ? renderSettings() :
      `<div class="page"><div class="empty-state"><div class="empty-icon">🚧</div><div>Σύντομα διαθέσιμο</div></div></div>`
    );
  if (S.modal) renderModal();
  bindEvents();
}

// ── LOGIN ──
function renderLogin() {
  return `<div class="login-screen">
    <div class="login-blob" style="width:400px;height:400px;background:rgba(43,59,240,0.12);top:-100px;right:-80px"></div>
    <div class="login-blob" style="width:280px;height:280px;background:rgba(43,59,240,0.07);bottom:40px;left:-60px"></div>
    <div class="login-wrap"><div class="login-card">
      <div style="text-align:center;margin-bottom:32px">
        <div style="display:inline-flex;margin-bottom:12px">
          <span style="width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,0.3);display:block"></span>
          <span style="width:20px;height:20px;border-radius:50%;background:var(--blue);margin-left:-7px;display:block"></span>
        </div>
        <div style="font-size:22px;font-weight:600;color:#fff;letter-spacing:-.5px">medi360</div>
        <div style="font-size:10px;color:rgba(255,255,255,0.3);letter-spacing:2px;text-transform:uppercase;margin-top:3px">CRM Platform</div>
      </div>
      <div id="login-err" style="display:none;background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.25);color:#fca5a5;font-size:12px;padding:9px 13px;border-radius:8px;margin-bottom:14px"></div>
      <label class="login-label">Email</label>
      <input class="login-input form-control" id="login-email" type="email" placeholder="email@clinic.gr" autocomplete="email"/>
      <label class="login-label">Κωδικός</label>
      <input class="login-input form-control" id="login-pass" type="password" placeholder="••••••••" autocomplete="current-password"/>
      <button id="login-btn" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px;border-radius:10px;font-size:14px;margin-top:6px">Σύνδεση →</button>
    </div></div>
  </div>`;
}

// ── SHELL ──
function renderShell(content) {
  const cid = clinicId();
  const collapsed = S.sidebarCollapsed;
  const role = (S.profile&&S.profile.role)||'';
  const NAV = [
    {page:'dashboard',icon:'◉',label:'Dashboard',roles:['super_admin','clinic_admin','therapist','receptionist']},
    {page:'patients',icon:'◎',label:'Ασθενείς',roles:['super_admin','clinic_admin','therapist','receptionist']},
    {page:'appointments',icon:'◷',label:'Ραντεβού',roles:['super_admin','clinic_admin','therapist','receptionist']},
    {page:'calendar',icon:'⊟',label:'Πρόγραμμα',roles:['super_admin','clinic_admin','therapist','receptionist']},
    {page:'pipeline',icon:'⟫',label:'Pipeline',roles:['super_admin','clinic_admin']},
    {page:'sms',icon:'✉',label:'SMS & Auto.',roles:['super_admin','clinic_admin']},
    {page:'laser',icon:'⚡',label:'Laser Forms',roles:['super_admin','clinic_admin','therapist']},
    {page:'consents',icon:'✓',label:'Συναινέσεις',roles:['super_admin','clinic_admin','therapist']},
    {page:'clinics',icon:'⊞',label:'Κλινικές',roles:['super_admin']},
    {page:'settings',icon:'⚙',label:'Ρυθμίσεις',roles:['super_admin','clinic_admin']},
  ].filter(n => n.roles.includes(role) && (isSuperAdmin() && !cid ? ['dashboard','clinics'].includes(n.page) : true));

  const PAGE_TITLES = {dashboard:'Dashboard',patients:'Ασθενείς','patient-detail':'Ασθενής',appointments:'Ραντεβού',calendar:'Πρόγραμμα',pipeline:'Pipeline',clinics:'Κλινικές',sms:'SMS & Αυτοματισμοί',laser:'Laser Forms',consents:'Συναινέσεις',settings:'Ρυθμίσεις'};

  return `
  <div class="overlay ${S.sidebarOpen?'open':''}" id="overlay"></div>
  <aside class="sidebar ${collapsed?'collapsed':''} ${S.sidebarOpen?'mobile-open':''}" id="sidebar">
    <div class="sidebar-logo">
      ${!collapsed?`<div>
        <div class="logo-circles"><span></span><span></span></div>
        <span class="logo-text">medi360</span>
        <span class="logo-sub">${isSuperAdmin()?'Super Admin':esc((S.clinic&&S.clinic.name)||'CRM')}</span>
      </div>`:`<div class="logo-circles"><span></span><span></span></div>`}
      <button class="collapse-btn" id="collapse-btn">${collapsed?'›':'‹'}</button>
    </div>
    ${isSuperAdmin()&&!collapsed?`
    <div class="clinic-picker" style="position:relative">
      <button class="clinic-picker-btn" id="clinic-picker-btn">
        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;text-align:left">${cid?((S.allClinics.find(c=>c.id===cid)||{}).name||'Κλινική'):'Επίλεξε κλινική...'}</span>
        <span style="margin-left:4px">▾</span>
      </button>
      <div class="clinic-dropdown" id="clinic-dropdown" style="display:none">
        ${S.allClinics.map(c=>`<div class="clinic-option ${c.id===cid?'selected':''}" data-clinic="${c.id}">${esc(c.name)}</div>`).join('')}
        <div class="clinic-option" style="color:var(--blue);border-top:1px solid var(--border)" data-page="clinics">+ Κλινικές</div>
      </div>
    </div>`:''}
    <nav class="sidebar-nav">
      ${NAV.map(n=>`<div class="nav-item ${S.page===n.page||S.page==='patient-detail'&&n.page==='patients'?'active':''}" data-page="${n.page}">
        <span class="nav-icon">${n.icon}</span><span class="nav-label">${n.label}</span>
      </div>`).join('')}
    </nav>
    <div class="sidebar-footer">
      <div class="user-info">
        <div class="user-avatar">${initials((S.profile&&S.profile.full_name))}</div>
        ${!collapsed?`<div style="flex:1;min-width:0">
          <div class="user-name">${esc((S.profile&&S.profile.full_name)||'User')}</div>
          <div class="user-role">${ROLES[(S.profile&&S.profile.role)]||(S.profile&&S.profile.role)}</div>
        </div>
        <button class="logout-btn" id="logout-btn" title="Αποσύνδεση">⎋</button>`:''}
      </div>
      ${collapsed?`<button class="logout-btn" id="logout-btn" title="Αποσύνδεση" style="margin-top:8px">⎋</button>`:''}
    </div>
  </aside>
  <div class="main ${collapsed?'expanded':''}" id="main">
    <header class="topbar">
      <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      <span class="topbar-title">${PAGE_TITLES[S.page]||'medi360'}</span>
      <!-- Global Search -->
      <div style="flex:1;max-width:320px;margin:0 16px;position:relative">
        <div style="display:flex;align-items:center;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:6px 12px;gap:8px">
          <span style="color:var(--text-3);font-size:14px">⌕</span>
          <input id="global-search" placeholder="Αναζήτηση ασθενή, ραντεβού..." value="${esc(S.globalSearch||'')}"
            style="border:none;background:transparent;font-size:12px;outline:none;width:100%;color:var(--text)"/>
          ${S.globalSearch?`<button onclick="S.globalSearch='';S.globalResults=[];render()" style="background:none;border:none;color:var(--text-3);cursor:pointer;font-size:16px;line-height:1">×</button>`:''}
        </div>
        ${S.globalSearch&&S.globalResults&&S.globalResults.length?`
        <div style="position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--white);border:1px solid var(--border-2);border-radius:10px;box-shadow:var(--shadow-lg);z-index:200;max-height:320px;overflow-y:auto">
          ${S.globalResults.map(r=>`
          <div style="padding:10px 14px;border-bottom:1px solid var(--border-2);cursor:pointer;display:flex;align-items:center;gap:10px" data-search-result="${r.type}" data-search-id="${r.id}">
            <div style="width:28px;height:28px;border-radius:6px;background:${r.type==='patient'?'#E6F1FB':r.type==='appointment'?'#E1F5EE':'#EEEDFE'};display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0">${r.type==='patient'?'◎':r.type==='appointment'?'◷':'⚡'}</div>
            <div style="flex:1;min-width:0">
              <div style="font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(r.title)}</div>
              <div style="font-size:11px;color:var(--text-2)">${esc(r.sub)}</div>
            </div>
            <div style="font-size:10px;color:var(--text-3)">${esc(r.tag)}</div>
          </div>`).join('')}
        </div>`:
        S.globalSearch&&S.globalResults&&S.globalResults.length===0?`
        <div style="position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--white);border:1px solid var(--border-2);border-radius:10px;box-shadow:var(--shadow-lg);z-index:200;padding:20px;text-align:center;color:var(--text-2);font-size:13px">
          Δεν βρέθηκαν αποτελέσματα
        </div>`:''}
      </div>
      <!-- Voice Agent Button -->
      <button id="voice-agent-btn" title="AI Voice Agent" style="width:36px;height:36px;border-radius:50%;background:${S.voiceActive?'var(--red)':'var(--blue)'};color:#fff;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;transition:.2s;${S.voiceActive?'animation:pulse 1s infinite':''}">${S.voiceActive?'⏹':'🎤'}</button>
      <span style="font-family:var(--mono);font-size:11px;color:var(--text-3)">${new Date().toLocaleDateString('el-GR')}</span>
    </header>
    <!-- Voice Agent Panel -->
    ${S.voiceActive||S.voiceResult?`
    <div style="background:var(--navy);color:#fff;padding:12px 20px;display:flex;align-items:center;gap:12px;font-size:13px">
      <div style="width:8px;height:8px;border-radius:50%;background:${S.voiceActive?'#ef4444':'#10b981'};${S.voiceActive?'animation:pulse 1s infinite':''}"></div>
      <span style="flex:1">${S.voiceActive?'🎤 Μιλάτε... (πείτε: "βρες Μαρία", "νέο ραντεβού", "άνοιξε dashboard")':esc(S.voiceResult||'')}</span>
      ${S.voiceResult?`<button onclick="S.voiceResult='';render()" style="background:none;border:none;color:rgba(255,255,255,0.5);cursor:pointer;font-size:16px">×</button>`:''}
    </div>`:''}
    <main>${content}</main>
  </div>`;
}

// ── DASHBOARD ──
function renderDashboard() {
  const pts = S.patients||[], apts = S.appointments||[];
  const today = new Date().toDateString();
  const now = new Date();
  const cid = clinicId();
  if (!cid && isSuperAdmin()) return `<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div style="font-size:14px;font-weight:500;margin-bottom:8px">Επίλεξε κλινική</div><div>Χρησιμοποίησε τον επιλογέα στα αριστερά</div></div></div>`;

  const canFin = canSee(['super_admin','clinic_admin']);
  const hour = now.getHours();
  const greet = hour<12?'Καλημέρα':hour<17?'Καλό απόγευμα':'Καλό βράδυ';

  // Stats
  const todayApts = apts.filter(a=>new Date(a.start_time).toDateString()===today);
  const upcomingApts = apts.filter(a=>new Date(a.start_time)>now&&a.status!=='cancelled').sort((a,b)=>new Date(a.start_time)-new Date(b.start_time));
  const thisMonth = apts.filter(a=>{const d=new Date(a.start_time);return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();});
  const revenue30 = apts.filter(a=>{const d=new Date(a.start_time);return (now-d)<30*86400000&&(a.status==='paid'||a.status==='completed');}).reduce((s,a)=>s+(a.price||0),0);
  const wonLeads = (S.pipeline||[]).filter(l=>l.stage==='won').length;
  const totalLeads = (S.pipeline||[]).length;
  const conversionRate = totalLeads ? Math.round((wonLeads/totalLeads)*100) : 0;
  const paidCompleted = apts.filter(a=>a.status==='paid'||a.status==='completed');
  const avgTicket = paidCompleted.length ? Math.round(paidCompleted.reduce((s,a)=>s+(a.price||0),0)/paidCompleted.length) : 0;
  const noShowRate = apts.length ? Math.round((apts.filter(a=>a.status==='no_show').length/apts.length)*100) : 0;
  const repeatPatients = pts.filter(p=>apts.filter(a=>a.patient_id===p.id).length>1).length;
  const repeatRate = pts.length ? Math.round((repeatPatients/pts.length)*100) : 0;
  const completedToday = todayApts.filter(a=>a.status==='completed'||a.status==='paid').length;
  const pendingToday = todayApts.filter(a=>a.status==='pending'||a.status==='confirmed').length;
  const noGdpr = pts.filter(p=>!p.gdpr_signed).length;
  const newPts30 = pts.filter(p=>(now-new Date(p.created_at))<30*86400000).length;

  // Next appointment
  const nextApt = upcomingApts[0];

  // Services breakdown (top 5)
  const svcCount = {};
  apts.forEach(a=>{ if(a.service_name) svcCount[a.service_name]=(svcCount[a.service_name]||0)+1; });
  const topServices = Object.entries(svcCount).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const maxSvc = topServices[0]?topServices[0][1]:1;

  return `<div class="page">
    <div class="page-header">
      <div>
        <h1 class="page-title">${greet}, ${esc(S.profile&&S.profile.full_name&&S.profile.full_name.split(' ')[0]||'!')} 👋</h1>
        <p class="page-sub">${now.toLocaleDateString('el-GR',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}</p>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost" data-page="calendar">📅 Πρόγραμμα</button>
        <button class="btn btn-primary" data-modal="new-appt">+ Νέο Ραντεβού</button>
      </div>
    </div>

    <!-- Stats grid -->
    <div class="stats-grid" style="margin-bottom:16px">
      <div class="stat-card">
        <div class="stat-icon" style="background:#eef0fe;color:var(--blue)">◎</div>
        <div class="stat-label">Σύνολο Ασθενών</div>
        <div class="stat-value" style="color:var(--blue)">${pts.length}</div>
        <div class="stat-change up">↑ ${newPts30} νέοι (30 μέρες)</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#E1F5EE;color:#0F6E56">◷</div>
        <div class="stat-label">Σήμερα</div>
        <div class="stat-value" style="color:#0F6E56">${todayApts.length}</div>
        <div class="stat-change">${completedToday} ✓ · ${pendingToday} εκκρεμούν</div>
      </div>
      ${canFin?`<div class="stat-card">
        <div class="stat-icon" style="background:#FAEEDA;color:#854F0B">€</div>
        <div class="stat-label">Έσοδα (30 μέρες)</div>
        <div class="stat-value" style="color:#854F0B">${euro(revenue30)}</div>
        <div class="stat-change up">↑ ${thisMonth.length} ραντεβού μήνα</div>
      </div>`:`<div class="stat-card">
        <div class="stat-icon" style="background:#FAEEDA;color:#854F0B">📅</div>
        <div class="stat-label">Αυτό το μήνα</div>
        <div class="stat-value" style="color:#854F0B">${thisMonth.length}</div>
        <div class="stat-change">ραντεβού</div>
      </div>`}
      <div class="stat-card">
        <div class="stat-icon" style="background:#FCEBEB;color:#A32D2D">⚠</div>
        <div class="stat-label">Χωρίς GDPR</div>
        <div class="stat-value" style="color:#A32D2D">${noGdpr}</div>
        <div class="stat-change">${pts.filter(p=>p.status==='vip').length} VIP · ${pts.filter(p=>p.status==='lead').length} leads</div>
      </div>
    </div>

    <!-- Commercial health KPIs -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px" class="dash-grid">
      ${[
        {l:'Conversion Lead → Patient',v:conversionRate+'%',sub:wonLeads+' κερδισμένα / '+totalLeads+' leads'},
        {l:'Μέσο Ticket',v:euro(avgTicket),sub:paidCompleted.length+' ολοκληρωμένα/paid'},
        {l:'Repeat Rate',v:repeatRate+'%',sub:repeatPatients+' ασθενείς με >1 επίσκεψη'},
        {l:'No-show Rate',v:noShowRate+'%',sub:apts.filter(a=>a.status==='no_show').length+' no-shows'}
      ].map(k=>`<div style="background:var(--white);border:1px solid var(--border-2);border-radius:10px;padding:12px 14px;box-shadow:var(--shadow-sm)">
        <div style="font-size:10px;color:var(--text-2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px">${k.l}</div>
        <div style="font-size:20px;font-weight:600;color:var(--navy);line-height:1">${k.v}</div>
        <div style="font-size:11px;color:var(--text-3);margin-top:5px">${k.sub}</div>
      </div>`).join('')}
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px" class="dash-grid">

      <!-- Today's schedule -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">📅 Σήμερα</span>
          <div style="display:flex;align-items:center;gap:8px">
            <span class="badge" style="background:#eef0fe;color:var(--blue)">${todayApts.length} ραντεβού</span>
            <button class="btn btn-ghost btn-sm" data-page="calendar">Πρόγραμμα →</button>
          </div>
        </div>
        <div style="max-height:320px;overflow-y:auto">
          ${todayApts.length?todayApts.sort((a,b)=>new Date(a.start_time)-new Date(b.start_time)).map(a=>{
            const isPast = new Date(a.start_time)<now;
            const c = (STATUS_APPT[a.status]||STATUS_APPT.pending);
            return `<div style="display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border-2);${isPast?'opacity:0.6':''}">
              <div style="width:4px;align-self:stretch;border-radius:2px;background:${c.c};flex-shrink:0"></div>
              <div style="font-family:var(--mono);font-size:12px;font-weight:500;color:var(--blue);flex-shrink:0;min-width:42px">${new Date(a.start_time).toLocaleTimeString('el-GR',{hour:'2-digit',minute:'2-digit'})}</div>
              <div style="flex:1;min-width:0;cursor:pointer" ${a.patient_id?`data-patient="${a.patient_id}"`:''}> 
                <div style="font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(a.patients&&a.patients.full_name||'—')}</div>
                <div style="font-size:11px;color:var(--text-2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(a.service_name||'')}</div>
              </div>
              ${apptBadge(a.status)}
            </div>`;
          }).join(''):`<div style="padding:40px;text-align:center;color:var(--text-2);font-size:12px">
            <div style="font-size:24px;margin-bottom:8px">🎉</div>
            Δεν υπάρχουν ραντεβού σήμερα
          </div>`}
        </div>
      </div>

      <!-- Upcoming + Next apt -->
      <div style="display:flex;flex-direction:column;gap:16px">
        ${nextApt?`<div class="card" style="padding:16px;border-left:4px solid var(--blue)">
          <div style="font-size:11px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Επόμενο Ραντεβού</div>
          <div style="display:flex;align-items:center;gap:12px">
            <div style="width:44px;height:44px;border-radius:10px;background:#eef0fe;display:flex;flex-direction:column;align-items:center;justify-content:center">
              <div style="font-size:16px;font-weight:700;color:var(--blue);line-height:1">${new Date(nextApt.start_time).getDate()}</div>
              <div style="font-size:9px;color:var(--blue)">${new Date(nextApt.start_time).toLocaleDateString('el-GR',{month:'short'})}</div>
            </div>
            <div style="flex:1">
              <div style="font-size:14px;font-weight:600;cursor:pointer" ${nextApt.patient_id?`data-patient="${nextApt.patient_id}"`:''}>${esc(nextApt.patients&&nextApt.patients.full_name||'—')}</div>
              <div style="font-size:12px;color:var(--text-2)">${esc(nextApt.service_name||'')}</div>
              <div style="font-size:12px;font-weight:500;color:var(--blue);margin-top:2px">${new Date(nextApt.start_time).toLocaleTimeString('el-GR',{hour:'2-digit',minute:'2-digit'})} · ${new Date(nextApt.start_time).toLocaleDateString('el-GR',{weekday:'long'})}</div>
            </div>
            ${apptBadge(nextApt.status)}
          </div>
        </div>`:''}

        <!-- Top services -->
        <div class="card" style="flex:1">
          <div class="card-header"><span class="card-title">📊 Top Υπηρεσίες</span></div>
          <div style="padding:14px 16px">
            ${topServices.length?topServices.map(([svc,cnt])=>`
            <div style="margin-bottom:10px">
              <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
                <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px">${esc(svc)}</span>
                <span style="font-weight:500;color:var(--blue);flex-shrink:0;margin-left:8px">${cnt}</span>
              </div>
              <div style="height:5px;background:var(--surface);border-radius:99px;overflow:hidden">
                <div style="height:100%;width:${Math.round(cnt/maxSvc*100)}%;background:var(--blue);border-radius:99px;transition:.3s"></div>
              </div>
            </div>`).join(''):`<div style="text-align:center;color:var(--text-2);padding:20px;font-size:12px">Δεν υπάρχουν δεδομένα</div>`}
          </div>
        </div>
      </div>
    </div>

    <!-- Recent patients -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Πρόσφατοι Ασθενείς</span>
        <button class="btn btn-ghost btn-sm" data-page="patients">Όλοι →</button>
      </div>
      <div class="table-wrap"><table>
        <thead><tr><th>Ασθενής</th><th>Τηλέφωνο</th><th class="hide-mobile">Πηγή</th><th class="hide-mobile">GDPR</th><th>Κατάσταση</th></tr></thead>
        <tbody>${pts.slice(0,8).map(p=>`<tr data-patient="${p.id}">
          <td><div style="display:flex;align-items:center;gap:8px">
            <div style="width:28px;height:28px;border-radius:50%;background:#E6F1FB;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:#185FA5;flex-shrink:0">${initials(p.full_name)}</div>
            <div><div style="font-weight:500">${esc(p.full_name)}</div></div>
          </div></td>
          <td style="font-family:var(--mono);font-size:12px;color:var(--text-2)">${esc(p.phone||'—')}</td>
          <td class="hide-mobile" style="font-size:12px;color:var(--text-2)">${esc(p.source||'—')}</td>
          <td class="hide-mobile">${p.gdpr_signed?'<span style="color:#0F6E56">✓</span>':'<span style="color:#A32D2D">✗</span>'}</td>
          <td>${patBadge(p.status)}</td>
        </tr>`).join('')||'<tr><td colspan="5"><div class="empty-state" style="padding:20px"><div>Δεν υπάρχουν ασθενείς</div></div></td></tr>'}
        </tbody>
      </table></div>
    </div>
  </div>`;
}


// ── PATIENTS ──
function renderPatients() {
  const cid = clinicId();
  if (!cid) return '<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div>Επίλεξε κλινική</div></div></div>';
  const filtered = S.patients.filter(p=>{
    // Use global search if on patients page
    const q = (S.globalSearch||S.search||'').toLowerCase();
    const qGreek = q ? latinToGreek(q) : '';
    const ms = !q ||
      (p.full_name&&(p.full_name.toLowerCase().includes(q)||p.full_name.toLowerCase().includes(qGreek))) ||
      (p.phone&&p.phone.includes(q)) ||
      (p.email&&p.email.toLowerCase().includes(q));
    const mf = S.filter==='all'||p.status===S.filter;
    return ms&&mf;
  });
  return `<div class="page">
    <div class="page-header">
      <div><h1 class="page-title">Ασθενείς</h1><p class="page-sub">${S.patients.length} συνολικά · ${S.patients.filter(p=>p.status==='active').length} ενεργοί</p></div>
      <button class="btn btn-primary" data-modal="new-patient">+ Νέος Ασθενής</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px">
      ${[{l:'Σύνολο',v:S.patients.length,bg:'var(--surface)'},{l:'Ενεργοί',v:S.patients.filter(p=>p.status==='active').length,bg:'#E1F5EE'},{l:'VIP',v:S.patients.filter(p=>p.status==='vip').length,bg:'#EEEDFE'},{l:'Leads',v:S.patients.filter(p=>p.status==='lead').length,bg:'#E6F1FB'}].map(s=>`
      <div style="background:${s.bg};border-radius:8px;padding:10px 14px"><div style="font-size:11px;color:var(--text-2);margin-bottom:2px">${s.l}</div><div style="font-size:20px;font-weight:500">${s.v}</div></div>`).join('')}
    </div>
    <div style="display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;align-items:center">
      <div class="filter-tabs">
        ${['all','active','vip','lead','inactive'].map(f=>`<button class="filter-tab ${S.filter===f?'active':''}" data-filter="${f}">${f==='all'?'Όλοι':(STATUS_PAT[f]&&STATUS_PAT[f].l)||f}</button>`).join('')}
      </div>
      <div style="font-size:12px;color:var(--text-2);margin-left:auto">${filtered.length} από ${S.patients.length}</div>
    </div>
    <div class="card">
      <div class="table-wrap"><table>
        <thead><tr><th>Ασθενής</th><th class="hide-mobile">Τηλέφωνο</th><th>Κατάσταση</th><th class="hide-mobile">GDPR</th><th class="hide-mobile">LTV</th><th></th></tr></thead>
        <tbody>${filtered.length?filtered.map(p=>`<tr data-patient="${p.id}">
          <td><div style="display:flex;align-items:center;gap:9px">
            <div style="width:28px;height:28px;border-radius:50%;background:#E6F1FB;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:#185FA5;flex-shrink:0">${initials(p.full_name)}</div>
            <div><div style="font-weight:500;font-size:13px">${esc(p.full_name)}</div>${p.email?`<div style="font-size:11px;color:var(--text-2)">${esc(p.email)}</div>`:''}</div>
          </div></td>
          <td class="hide-mobile" style="font-family:var(--mono);font-size:12px;color:var(--text-2)">${esc(p.phone||'—')}</td>
          <td>${patBadge(p.status)}</td>
          <td class="hide-mobile">${p.gdpr_signed?'✅':'❌'}</td>
          <td class="hide-mobile" style="font-weight:500;color:#0F6E56">${euro(p.ltv)}</td>
          <td><button class="btn btn-ghost btn-xs" data-patient="${p.id}">Άνοιγμα</button></td>
        </tr>`).join(''):`<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">◎</div><div>Δεν βρέθηκαν ασθενείς</div></div></td></tr>`}
        </tbody>
      </table></div>
    </div>
  </div>`;
}

// ── PATIENT DETAIL ──
function renderPatientDetail() {
  const p = S.patientDetail;
  if (!p) return '<div class="page"><div class="empty-state"><div>Φόρτωση...</div></div></div>';
  const patTab = S.patTab||'overview';
  const laserForms = (S.laserForms||[]).filter(f=>f.patient_id===p.id);
  const consultations = (S.patConsultations||[]);
  const canSeeFinancials = canSee(['super_admin','clinic_admin']);

  return `<div class="page">
    <!-- Header -->
    <div class="page-header">
      <div style="display:flex;align-items:center;gap:12px">
        <button class="btn btn-ghost btn-sm" data-page="patients">← Πίσω</button>
        <div style="width:44px;height:44px;border-radius:50%;background:#E6F1FB;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;color:#185FA5">${initials(p.full_name)}</div>
        <div>
          <h1 class="page-title" style="font-size:18px">${esc(p.full_name)}</h1>
          <div style="display:flex;gap:8px;align-items:center;margin-top:4px">
            ${patBadge(p.status)}
            <span style="font-size:12px;color:var(--text-2)">${esc(p.phone||'')}</span>
            ${p.gdpr_signed?'<span style="font-size:11px;color:#0F6E56">✓ GDPR</span>':'<span style="font-size:11px;color:var(--red)">⚠ Χωρίς GDPR</span>'}
          </div>
        </div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" data-modal="new-appt">+ Ραντεβού</button>
        <button class="btn btn-primary btn-sm" data-modal="new-laser">+ Laser Form</button>
      </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:0;border-bottom:1px solid var(--border-2);margin-bottom:20px">
      ${[
        {id:'overview',l:'Στοιχεία'},
        {id:'timeline',l:'Timeline'},
        {id:'appointments',l:`Ραντεβού (${(p.appointments&&p.appointments.length)||0})`},
        {id:'medical',l:`Ιατρικό Ιστορικό${p.medical_history||p.allergies?' ✓':''}`},
        {id:'laser',l:`Laser Forms (${laserForms.length})`},
        {id:'consultation',l:`Consultation (${consultations.length})`},
      ].map(t=>`<button class="btn" style="border-radius:0;border-bottom:2px solid ${patTab===t.id?'var(--blue)':'transparent'};color:${patTab===t.id?'var(--blue)':'var(--text-2)'};background:transparent;padding:8px 14px;font-size:12px;white-space:nowrap" data-pat-tab="${t.id}">${t.l}</button>`).join('')}
    </div>

    <!-- TIMELINE TAB -->
    ${patTab==='timeline'?`
    <div style="position:relative;padding-left:32px">
      <!-- Vertical line -->
      <div style="position:absolute;left:10px;top:0;bottom:0;width:2px;background:var(--border-2)"></div>
      ${(()=>{
        // Build timeline events from all sources
        const events = [];
        // Registration
        events.push({date:p.created_at,type:'register',icon:'👤',color:'#2B3BF0',bg:'#eef0fe',title:'Εγγραφή ασθενή',desc:`Πηγή: ${p.source||'—'}`});
        // GDPR
        if (p.gdpr_signed) events.push({date:p.gdpr_signed_at||p.created_at,type:'gdpr',icon:'✓',color:'#0F6E56',bg:'#E1F5EE',title:'GDPR Υπογεγραμμένο',desc:'Συναίνεση δεδομένων'});
        // Medical history
        if (p.medical_history) events.push({date:p.medical_history_date||p.created_at,type:'medical',icon:'🏥',color:'#185FA5',bg:'#E6F1FB',title:'Ιατρικό Ιστορικό',desc:p.medical_history.slice(0,80)+(p.medical_history.length>80?'...':'')});
        // Appointments
        (p.appointments||[]).forEach(a=>{
          const st=STATUS_APPT[a.status]||STATUS_APPT.pending;
          events.push({date:a.start_time,type:'appt',icon:'◷',color:st.c,bg:st.bg,
            title:a.service_name||'Ραντεβού',
            desc:`${fmtDt(a.start_time)}${canSeeFinancials&&a.price?' · '+euro(a.price):''}`,
            badge:apptBadge(a.status)});
        });
        // Laser forms
        laserForms.forEach(f=>{
          events.push({date:f.created_at,type:'laser',icon:'⚡',color:'#534AB7',bg:'#EEEDFE',
            title:'Laser Form — Συνεδρία #'+(f.session_number||1),
            desc:(f.body_parts||[]).slice(0,3).join(', ')});
        });
        // Sort by date desc
        events.sort((a,b)=>new Date(b.date)-new Date(a.date));
        if (!events.length) return '<div class="empty-state"><div class="empty-icon">📅</div><div>Δεν υπάρχουν γεγονότα</div></div>';
        return events.map(e=>`
          <div style="position:relative;margin-bottom:20px;display:flex;gap:14px;align-items:flex-start">
            <!-- Dot -->
            <div style="position:absolute;left:-36px;width:20px;height:20px;border-radius:50%;background:${e.bg};border:2px solid ${e.color};display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;z-index:1">${e.icon}</div>
            <!-- Content -->
            <div style="background:var(--white);border:1px solid var(--border-2);border-radius:10px;padding:12px 14px;flex:1;box-shadow:var(--shadow-sm)">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
                <div style="font-size:13px;font-weight:500;color:var(--navy)">${esc(e.title)}</div>
                <div style="font-size:10px;color:var(--text-3);white-space:nowrap;font-family:var(--mono)">${fmt(e.date)}</div>
              </div>
              ${e.desc?`<div style="font-size:12px;color:var(--text-2);margin-top:3px">${esc(e.desc)}</div>`:''}
              ${e.badge?`<div style="margin-top:6px">${e.badge}</div>`:''}
            </div>
          </div>`).join('');
      })()}
    </div>`:''}

    <!-- OVERVIEW TAB -->
    ${patTab==='overview'?`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px" class="dash-grid">
      <div class="card">
        <div class="card-header"><span class="card-title">Στοιχεία Ασθενή</span>
          <button class="btn btn-ghost btn-sm" id="edit-patient-btn">✏ Επεξεργασία</button>
        </div>
        <div style="padding:16px">
          ${[
            ['Email', p.email],
            ['Τηλέφωνο', p.phone],
            ['Ημ. Γέννησης', fmt(p.dob)],
            ['Φύλο', p.gender==='female'?'Γυναίκα':p.gender==='male'?'Άνδρας':'Άλλο'],
            ['Πόλη', p.city],
            ['Πηγή', p.source],
            ['GDPR', p.gdpr_signed?'✅ Υπογεγραμμένο':'❌ Όχι'],
            ['Ιατρικό Ιστορικό', p.medical_history_completed?'✅ Συμπληρωμένο':'❌ Όχι'],
            ...(canSeeFinancials?[['LTV', euro(p.ltv)]]:[] ),
            ['Εγγραφή', fmt(p.created_at)],
          ].map(([k,v])=>`
          <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-2);font-size:13px">
            <span style="color:var(--text-2)">${k}</span><span style="font-weight:500">${esc(v||'—')}</span>
          </div>`).join('')}
        </div>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">Σύνοψη Δραστηριότητας</span></div>
        <div style="padding:16px">
          ${[
            ['Σύνολο Ραντεβού', (p.appointments&&p.appointments.length)||0],
            ['Ολοκληρωμένα', (p.appointments||[]).filter(a=>a.status==='completed'||a.status==='paid').length],
            ['Laser Forms', laserForms.length],
            ['Consultations', consultations.length],
            ...(canSeeFinancials?[['Σύνολο Εσόδων', euro((p.appointments||[]).filter(a=>a.price).reduce((s,a)=>s+(a.price||0),0))]]:[]),
            ['Τελευταία Επίσκεψη', fmtDt((p.appointments||[])[0]&&(p.appointments||[])[0].start_time)],
          ].map(([k,v])=>`
          <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-2);font-size:13px">
            <span style="color:var(--text-2)">${k}</span><span style="font-weight:500">${esc(String(v||'—'))}</span>
          </div>`).join('')}
          ${p.notes?`<div style="margin-top:12px"><div style="font-size:11px;font-weight:600;color:var(--text-2);text-transform:uppercase;margin-bottom:6px">Σημειώσεις</div><div style="font-size:13px;line-height:1.6;color:var(--text-2)">${esc(p.notes)}</div></div>`:''}
        </div>
      </div>
    </div>`:''}

    <!-- APPOINTMENTS TAB -->
    ${patTab==='appointments'?`
    <div class="card">
      <div class="card-header">
        <span class="card-title">Ιστορικό Ραντεβού</span>
        <button class="btn btn-primary btn-sm" data-modal="new-appt">+ Νέο</button>
      </div>
      <div style="max-height:600px;overflow-y:auto">
        ${(p.appointments||[]).length?
          (p.appointments||[]).map(a=>`
          <div style="padding:14px 18px;border-bottom:1px solid var(--border-2);display:flex;align-items:center;gap:14px">
            <div style="width:4px;align-self:stretch;border-radius:2px;background:${(STATUS_APPT[a.status]||STATUS_APPT.pending).c};flex-shrink:0"></div>
            <div style="flex:1">
              <div style="font-size:13px;font-weight:500">${esc(a.service_name||'—')}</div>
              <div style="font-size:11px;color:var(--text-2)">${fmtDt(a.start_time)}</div>
            </div>
            ${canSeeFinancials&&a.price?`<div style="font-size:13px;font-weight:500;color:#0F6E56">${euro(a.price)}</div>`:''}
            ${apptBadge(a.status)}
          </div>`).join('')
        :'<div style="padding:40px;text-align:center;color:var(--text-2)">Δεν υπάρχουν ραντεβού</div>'}
      </div>
    </div>`:''}

    <!-- MEDICAL TAB -->
    ${patTab==='medical'?`
    <div style="display:flex;flex-direction:column;gap:16px">
      ${p.gdpr_signed||p.medical_history||p.allergies||p.medications||p.previous_treatments?`
      <div class="card">
        <div class="card-header">
          <span class="card-title">🏥 Ιατρικό Ιστορικό & GDPR</span>
          <div style="display:flex;gap:8px;align-items:center">
            ${p.gdpr_signed?'<span class="badge badge-green">✓ GDPR Υπογεγραμμένο</span>':'<span class="badge badge-red">⚠ Χωρίς GDPR</span>'}
            <button class="btn btn-ghost btn-sm" id="sync-patient-sheet-btn">🔄 Sync από Sheet</button>
          </div>
        </div>
        <div style="padding:16px;display:grid;grid-template-columns:1fr 1fr;gap:20px">
          ${p.medical_history?`<div>
            <div style="font-size:10px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px">ΙΑΤΡΙΚΟ ΙΣΤΟΡΙΚΟ</div>
            <div style="font-size:13px;line-height:1.7;color:var(--text)">${esc(p.medical_history)}</div>
          </div>`:''}
          ${p.allergies?`<div>
            <div style="font-size:10px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px">ΑΛΛΕΡΓΙΕΣ</div>
            <div style="font-size:13px;line-height:1.7;color:var(--text)">${esc(p.allergies)}</div>
          </div>`:''}
          ${p.medications?`<div>
            <div style="font-size:10px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px">ΦΑΡΜΑΚΕΥΤΙΚΗ ΑΓΩΓΗ / ΠΑΘΗΣΕΙΣ</div>
            <div style="font-size:13px;line-height:1.7;color:var(--text)">${esc(p.medications)}</div>
          </div>`:''}
          ${p.previous_treatments?`<div>
            <div style="font-size:10px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px">ΠΡΟΗΓΟΥΜΕΝΕΣ ΘΕΡΑΠΕΙΕΣ</div>
            <div style="font-size:13px;line-height:1.7;color:var(--text)">${esc(p.previous_treatments)}</div>
          </div>`:''}
        </div>
        ${!p.medical_history&&!p.allergies?`<div style="padding:0 16px 16px;font-size:12px;color:var(--text-2)">Δεν υπάρχουν ιατρικά στοιχεία. Κάνε Sync για να φορτώσεις από το Google Sheet.</div>`:''}
      </div>`:`
      <div class="empty-state">
        <div class="empty-icon">🏥</div>
        <div style="margin-bottom:12px">Δεν υπάρχει ιατρικό ιστορικό</div>
        <div style="font-size:12px;color:var(--text-3);margin-bottom:12px">Συμπληρώνεται μέσω Google Form και συγχρονίζεται αυτόματα</div>
        <button class="btn btn-primary btn-sm" id="sync-patient-sheet-btn">🔄 Sync από Google Sheets τώρα</button>
      </div>`}
    </div>`:''}

    <!-- LASER FORMS TAB -->
    ${patTab==='laser'?`
    <div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <span style="font-size:13px;color:var(--text-2)">${laserForms.length} φόρμες</span>
        <button class="btn btn-primary btn-sm" data-modal="new-laser">+ Νέο Laser Form</button>
      </div>
      ${laserForms.length?`
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px">
        ${laserForms.map(f=>`
        <div class="card" style="padding:16px;cursor:pointer" data-laser="${f.id}">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
            <div style="width:32px;height:32px;border-radius:8px;background:#EEEDFE;display:flex;align-items:center;justify-content:center;font-size:16px">⚡</div>
            <div>
              <div style="font-size:13px;font-weight:500">Συνεδρία #${f.session_number||1}</div>
              <div style="font-size:11px;color:var(--text-2)">${fmt(f.created_at)}</div>
            </div>
          </div>
          ${f.body_parts&&f.body_parts.length?`<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px">
            ${f.body_parts.slice(0,5).map(bp=>`<span style="font-size:9px;padding:2px 6px;border-radius:6px;background:#EEEDFE;color:#534AB7">${esc(bp)}</span>`).join('')}
            ${f.body_parts.length>5?`<span style="font-size:9px;color:var(--text-2)">+${f.body_parts.length-5}</span>`:''}
          </div>`:''}
          <div style="display:flex;gap:6px">
            ${f.consent_signed?'<span class="badge badge-green" style="font-size:10px">✓ Συναίνεση</span>':'<span class="badge badge-amber" style="font-size:10px">⚠ Χωρίς Συναίνεση</span>'}
            <span class="badge badge-navy" style="font-size:10px">${f.gender==='female'?'Γυναίκα':'Άνδρας'}</span>
          </div>
        </div>`).join('')}
      </div>`:`
      <div class="empty-state">
        <div class="empty-icon">⚡</div>
        <div style="margin-bottom:12px">Δεν υπάρχουν Laser Forms</div>
        <button class="btn btn-primary btn-sm" data-modal="new-laser">+ Δημιούργησε πρώτο</button>
      </div>`}
    </div>`:''}

    <!-- CONSULTATION TAB -->
    ${patTab==='consultation'?`
    <div>
      ${consultations.length?`
      <div style="display:flex;flex-direction:column;gap:12px">
        ${consultations.map((c,i)=>`
        <div class="card" style="padding:16px">
          <div style="display:flex;justify-content:space-between;margin-bottom:12px">
            <div style="font-size:13px;font-weight:500">Consultation #${i+1}</div>
            <div style="font-size:11px;color:var(--text-2);font-family:var(--mono)">${fmt(c.timestamp||c.Timestamp)}</div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            ${Object.entries(c).filter(([k])=>!['timestamp','Timestamp','Ονοματεπώνυμο','Ονοματεπώνυμο:','Τηλέφωνο','Τηλέφωνο:','Email','Email:'].includes(k)&&k&&c[k]).map(([k,v])=>`
            <div>
              <div style="font-size:10px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">${esc(k)}</div>
              <div style="font-size:12px;line-height:1.5">${esc(v)}</div>
            </div>`).join('')}
          </div>
        </div>`).join('')}
      </div>`:`
      <div class="empty-state">
        <div class="empty-icon">📋</div>
        <div style="margin-bottom:8px">Δεν υπάρχουν Consultations</div>
        <div style="font-size:12px;color:var(--text-3)">Τα consultations φορτώνονται από το Google Sheet<br>που έχεις ρυθμίσει στις Ρυθμίσεις → Συνδέσεις</div>
        <button class="btn btn-ghost btn-sm" style="margin-top:12px" id="load-consultations-btn">🔄 Φόρτωση από Google Sheets</button>
      </div>`}
    </div>`:''}
  </div>`;
}

// ── APPOINTMENTS ──
function renderAppointments() {
  const cid = clinicId();
  if (!cid) return '<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div>Επίλεξε κλινική</div></div></div>';
  const filtered = S.filter==='all'?S.appointments:S.appointments.filter(a=>a.status===S.filter);
  return `<div class="page">
    <div class="page-header">
      <div><h1 class="page-title">Ραντεβού</h1><p class="page-sub">${S.appointments.length} συνολικά</p></div>
      <button class="btn btn-primary" data-modal="new-appt">+ Νέο Ραντεβού</button>
    </div>
    <div class="filter-tabs" style="margin-bottom:16px">
      ${['all',...Object.keys(STATUS_APPT)].map(f=>`<button class="filter-tab ${S.filter===f?'active':''}" data-filter="${f}">${f==='all'?`Όλα (${S.appointments.length})`:(STATUS_APPT[f]&&STATUS_APPT[f].l)||f}</button>`).join('')}
    </div>
    <div style="display:flex;flex-direction:column;gap:8px">
      ${filtered.length?filtered.map(a=>{
        const st=STATUS_APPT[a.status]||STATUS_APPT.pending;
        return `<div class="appt-card">
          <div style="width:4px;align-self:stretch;border-radius:2px;background:${st.c};flex-shrink:0"></div>
          <div style="flex:1;min-width:0;cursor:pointer" ${a.patient_id?`data-patient="${a.patient_id}"`:''}  >
            <div style="font-size:13px;font-weight:500">${esc(a.patients&&a.patients.full_name||'—')}</div>
            <div style="font-size:11px;color:var(--text-2)">${esc(a.service_name||'')} · ${esc(a.patients&&a.patients.phone||'')}</div>
          </div>
          <div style="font-size:12px;color:var(--text-2);white-space:nowrap;flex-shrink:0">${fmtDt(a.start_time)}</div>
          ${a.price?`<div style="font-size:13px;font-weight:500;color:#0F6E56;flex-shrink:0">${euro(a.price)}</div>`:''}
          ${apptBadge(a.status)}
          <select data-appt-status="${a.id}" style="font-size:11px;padding:3px 6px;border-radius:6px;border:1px solid var(--border);background:transparent;cursor:pointer;font-family:var(--font)">
            ${Object.entries(STATUS_APPT).map(([k,v])=>`<option value="${k}" ${a.status===k?'selected':''}>${v.l}</option>`).join('')}
          </select>
        </div>`;
      }).join(''):`<div class="empty-state"><div class="empty-icon">◷</div><div>Δεν βρέθηκαν ραντεβού</div></div>`}
    </div>
  </div>`;
}

// ── PIPELINE ──
function renderPipeline() {
  const cid = clinicId();
  if (!cid) return '<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div>Επίλεξε κλινική</div></div></div>';
  return `<div class="page">
    <div class="page-header">
      <div><h1 class="page-title">Pipeline</h1><p class="page-sub">${S.pipeline.length} leads</p></div>
      <button class="btn btn-primary" data-modal="new-lead">+ Νέο Lead</button>
    </div>
    <div style="display:flex;gap:12px;overflow-x:auto;padding-bottom:12px">
      ${PIPELINE_STAGES.map(stage=>{
        const leads = S.pipeline.filter(l=>l.stage===stage);
        return `<div class="pipeline-col">
          <div style="font-size:11px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:.7px;margin-bottom:10px;display:flex;justify-content:space-between">
            <span>${STAGE_LABELS[stage]}</span><span style="background:var(--surface-2);padding:1px 7px;border-radius:99px">${leads.length}</span>
          </div>
          ${leads.map(l=>`<div class="pipeline-card">
            <div style="font-size:13px;font-weight:500;margin-bottom:4px">${esc(l.name)}</div>
            ${l.phone?`<div style="font-size:11px;color:var(--text-2);margin-bottom:6px">${esc(l.phone)}</div>`:''}
            ${l.service?`<span style="font-size:10px;background:#E6F1FB;color:#185FA5;padding:2px 7px;border-radius:99px">${esc(l.service)}</span>`:''}
            ${l.estimated_value?`<div style="font-size:12px;color:#0F6E56;font-weight:500;margin-top:4px">${euro(l.estimated_value)}</div>`:''}
          </div>`).join('')}
        </div>`;
      }).join('')}
    </div>
  </div>`;
}

// ── CLINICS ──
function renderClinics() {
  return `<div class="page">
    <div class="page-header">
      <div><h1 class="page-title">Κλινικές</h1><p class="page-sub">${S.clinics.length} κλινικές</p></div>
      <button class="btn btn-primary" data-modal="new-clinic">+ Νέα Κλινική</button>
    </div>
    <div class="card">
      <div class="table-wrap"><table>
        <thead><tr><th>Κλινική</th><th>Email</th><th>Τηλέφωνο</th><th>Πόλη</th><th>Κατάσταση</th></tr></thead>
        <tbody>${S.clinics.length?S.clinics.map(c=>`<tr>
          <td><div style="font-weight:500">${esc(c.name)}</div></td>
          <td style="color:var(--text-2)">${esc(c.email||'—')}</td>
          <td style="font-family:var(--mono);font-size:12px;color:var(--text-2)">${esc(c.phone||'—')}</td>
          <td style="color:var(--text-2)">${esc(c.city||'—')}</td>
          <td>${c.active?badge('Ενεργή','#E1F5EE','#0F6E56'):badge('Ανενεργή','#FCEBEB','#A32D2D')}</td>
        </tr>`).join(''):`<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">⊞</div><div>Δεν υπάρχουν κλινικές</div></div></td></tr>`}
        </tbody>
      </table></div>
    </div>
  </div>`;
}

// ── LASER FORMS ──
function renderLaserForms() {
  const cid = clinicId();
  if (!cid) return '<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div>Επίλεξε κλινική</div></div></div>';
  const forms = S.laserForms||[];
  return `<div class="page">
    <div class="page-header">
      <div><h1 class="page-title">Laser Forms</h1><p class="page-sub">${forms.length} φόρμες</p></div>
      <button class="btn btn-primary" data-modal="new-laser">+ Νέο Form</button>
    </div>
    ${forms.length===0?`<div class="empty-state"><div class="empty-icon">⚡</div><div style="margin-bottom:12px">Δεν υπάρχουν laser forms ακόμα</div><button class="btn btn-primary" data-page="patients">Πήγαινε στους ασθενείς</button></div>`:`
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      ${forms.map(f=>`<div class="card" style="padding:16px;cursor:pointer" data-laser="${f.id}">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
          <div style="width:32px;height:32px;border-radius:8px;background:#EEEDFE;display:flex;align-items:center;justify-content:center;font-size:16px">⚡</div>
          <div>
            <div style="font-size:13px;font-weight:500">${esc((f.patients&&f.patients.full_name)||'—')}</div>
            <div style="font-size:11px;color:var(--text-2)">${esc((f.patients&&f.patients.phone)||'')}</div>
          </div>
        </div>
        <div style="font-size:11px;color:var(--text-2);margin-bottom:6px">Συνεδρία #${f.session_number||1} · ${f.gender==='female'?'Γυναίκα':'Άνδρας'}</div>
        ${(f.body_parts&&f.body_parts.length)?`<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px">${f.body_parts.slice(0,4).map(p=>`<span style="font-size:9px;padding:2px 6px;border-radius:6px;background:#EEEDFE;color:#534AB7">${esc(p)}</span>`).join('')}${f.body_parts.length>4?`<span style="font-size:9px;color:var(--text-2)">+${f.body_parts.length-4}</span>`:''}</div>`:''}
        <div style="font-size:11px;color:var(--text-2)">${fmt(f.created_at)}</div>
      </div>`).join('')}
    </div>`}
  </div>`;
}

// ── CALENDAR ──
function renderCalendar() {
  const cid = clinicId();
  if (!cid) return '<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div>Επίλεξε κλινική</div></div></div>';

  const calView = S.calView||'day';
  const calMode = S.calMode||'therapist'; // therapist | room
  const calDate = S.calDate ? new Date(S.calDate) : new Date();
  const staff = S.staff||[];
  const appts = S.appointments||[];
  const canSeeFinancials = canSee(['super_admin','clinic_admin']);

  // Date navigation helpers
  const dateStr = calDate.toLocaleDateString('el-GR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  const weekStart = new Date(calDate);
  weekStart.setDate(calDate.getDate() - calDate.getDay() + 1); // Monday

  // Clinic hours (configurable per clinic, default 09:00-20:00)
  const startHour = (S.clinic&&S.clinic.settings&&S.clinic.settings.start_hour) || 9;
  const endHour = (S.clinic&&S.clinic.settings&&S.clinic.settings.end_hour) || 20;
  const hours = [];
  for (let h = startHour; h <= endHour; h++) hours.push(h);

  // Filter appointments for current view
  const dayAppts = appts.filter(a => {
    const d = new Date(a.start_time);
    return d.toDateString() === calDate.toDateString();
  });

  // Color by patient status
  const apptColor = (a) => {
    const st = a.patients&&a.patients.status;
    if (st==='vip') return {bg:'#EEEDFE',border:'#534AB7',text:'#3C3489'};
    if (st==='lead') return {bg:'#E6F1FB',border:'#2B3BF0',text:'#185FA5'};
    if (a.status==='cancelled') return {bg:'#FCEBEB',border:'#D85A30',text:'#A32D2D'};
    if (a.status==='completed'||a.status==='paid') return {bg:'#E1F5EE',border:'#1D9E75',text:'#0F6E56'};
    if (a.status==='confirmed') return {bg:'#E6F1FB',border:'#2B3BF0',text:'#185FA5'};
    return {bg:'#FAEEDA',border:'#EF9F27',text:'#854F0B'};
  };

  // Slot height: 60px per hour, so 1min = 1px
  const PX_PER_MIN = 1.2;
  const HOUR_H = 60 * PX_PER_MIN;

  // Columns: either staff or rooms
  const cols = calMode==='therapist'
    ? (staff.length ? staff : [{id:'unassigned',full_name:'Μη ανατεθειμένα'}])
    : [{id:'room1',full_name:'Δωμάτιο 1'},{id:'room2',full_name:'Δωμάτιο 2'},{id:'room3',full_name:'Δωμάτιο 3'}];

  const renderDayView = () => {
    return `
    <div style="display:flex;overflow:auto;border:1px solid var(--border-2);border-radius:12px;background:var(--white);flex:1">
      <!-- Time column -->
      <div style="width:56px;flex-shrink:0;border-right:1px solid var(--border-2)">
        <div style="height:48px;border-bottom:1px solid var(--border-2)"></div>
        ${hours.map(h=>`<div style="height:${HOUR_H}px;border-bottom:1px solid var(--border-2);padding:4px 6px;font-size:10px;color:var(--text-3);font-family:var(--mono);text-align:right">${h}:00</div>`).join('')}
      </div>
      <!-- Staff columns -->
      ${cols.map(col=>{
        const colAppts = calMode==='therapist'
          ? dayAppts.filter(a=>a.therapist_id===col.id||(col.id==='unassigned'&&!a.therapist_id))
          : dayAppts.filter(a=>a.room_id===col.id);

        return `<div style="flex:1;min-width:160px;border-right:1px solid var(--border-2);position:relative">
          <!-- Header -->
          <div style="height:48px;border-bottom:1px solid var(--border-2);display:flex;align-items:center;justify-content:center;padding:0 8px;background:var(--surface);position:sticky;top:0;z-index:10">
            <div style="text-align:center">
              <div style="font-size:12px;font-weight:500;color:var(--navy)">${esc(col.full_name)}</div>
              <div style="font-size:10px;color:var(--text-3)">${colAppts.length} ραντεβού</div>
            </div>
          </div>
          <!-- Hour grid -->
          <div style="position:relative;height:${hours.length*HOUR_H}px">
            ${hours.map(h=>`
              <div style="position:absolute;left:0;right:0;top:${(h-startHour)*HOUR_H}px;height:${HOUR_H}px;border-bottom:1px solid var(--border-2)">
                <div style="position:absolute;left:0;right:0;top:50%;height:1px;background:rgba(0,0,0,0.03)"></div>
              </div>`).join('')}
            <!-- Appointments -->
            ${colAppts.map(a=>{
              const start = new Date(a.start_time);
              const dur = a.duration_minutes||60;
              const topMin = (start.getHours()-startHour)*60 + start.getMinutes();
              const topPx = topMin * PX_PER_MIN;
              const heightPx = Math.max(dur*PX_PER_MIN, 24);
              const c = apptColor(a);
              const gdpr = a.patients&&a.patients.gdpr_signed;
              const isVip = a.patients&&a.patients.status==='vip';
              const startTime = start.toLocaleTimeString('el-GR',{hour:'2-digit',minute:'2-digit'});
              const endTime = new Date(start.getTime()+dur*60000).toLocaleTimeString('el-GR',{hour:'2-digit',minute:'2-digit'});

              return `<div
                data-appt-cal="${a.id}"
                style="position:absolute;left:3px;right:3px;top:${topPx}px;height:${heightPx}px;
                  background:${c.bg};border-left:3px solid ${c.border};border-radius:6px;
                  padding:3px 6px;cursor:pointer;overflow:hidden;z-index:5;transition:.15s"
                onmouseover="showCalTooltip(this, event)"
                onmouseout="hideCalTooltip(this)"
                data-name="${esc(a.patients&&a.patients.full_name||'—')}"
                data-service="${esc(a.service_name||'')}"
                data-time="${startTime} – ${endTime} (${dur} λεπτά)"
                data-gdpr="${gdpr?'1':'0'}"
                data-vip="${isVip?'1':'0'}"
                data-price="${canSeeFinancials&&a.price?euro(a.price):''}">
                <div style="font-size:10px;font-weight:500;color:${c.text};white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                  ${isVip?'★ ':''}${esc(a.patients&&a.patients.full_name||'—')}
                </div>
                ${heightPx>30?`<div style="font-size:9px;color:${c.text};opacity:0.8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${esc(a.service_name||'')}</div>`:''}
                ${heightPx>44?`<div style="font-size:9px;color:${c.text};opacity:0.7">${startTime}${!gdpr?' ⚠':''}</div>`:''}
              </div>`;
            }).join('')}
          </div>
        </div>`;
      }).join('')}
    </div>`;
  };

  const renderWeekView = () => {
    const weekDays = [];
    for (let i=0;i<7;i++) {
      const d = new Date(weekStart);
      d.setDate(weekStart.getDate()+i);
      weekDays.push(d);
    }
    return `
    <div style="overflow:auto;border:1px solid var(--border-2);border-radius:12px;background:var(--white)">
      <div style="display:grid;grid-template-columns:56px repeat(7,1fr);min-width:700px">
        <div style="height:48px;border-bottom:1px solid var(--border-2);border-right:1px solid var(--border-2)"></div>
        ${weekDays.map(d=>{
          const isToday = d.toDateString()===new Date().toDateString();
          const dayAppts2 = appts.filter(a=>new Date(a.start_time).toDateString()===d.toDateString());
          return `<div style="height:48px;border-bottom:1px solid var(--border-2);border-right:1px solid var(--border-2);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;background:${isToday?'var(--blue-soft)':'var(--surface)'}" data-cal-day="${d.toISOString()}">
            <div style="font-size:10px;color:var(--text-2)">${d.toLocaleDateString('el-GR',{weekday:'short'})}</div>
            <div style="font-size:16px;font-weight:${isToday?600:400};color:${isToday?'var(--blue)':'var(--navy)'}">${d.getDate()}</div>
            ${dayAppts2.length?`<div style="width:16px;height:4px;border-radius:2px;background:var(--blue);margin-top:2px"></div>`:''}
          </div>`;
        }).join('')}
        <!-- Time rows -->
        ${hours.map(h=>`
          <div style="height:${HOUR_H}px;border-bottom:1px solid var(--border-2);border-right:1px solid var(--border-2);padding:3px 6px;font-size:9px;color:var(--text-3);font-family:var(--mono);text-align:right;display:flex;align-items:flex-start;justify-content:flex-end">${h}:00</div>
          ${weekDays.map(d=>{
            const dayAppts3 = appts.filter(a=>{
              const ad=new Date(a.start_time);
              return ad.toDateString()===d.toDateString()&&ad.getHours()===h;
            });
            return `<div style="height:${HOUR_H}px;border-bottom:1px solid var(--border-2);border-right:1px solid var(--border-2);position:relative;padding:1px">
              ${dayAppts3.map(a=>{
                const c=apptColor(a);
                return `<div data-appt-cal="${a.id}" style="background:${c.bg};border-left:2px solid ${c.border};border-radius:3px;padding:1px 3px;font-size:9px;color:${c.text};margin-bottom:1px;cursor:pointer;overflow:hidden;white-space:nowrap;text-overflow:ellipsis" title="${esc(a.patients&&a.patients.full_name||'')} · ${esc(a.service_name||'')}">
                  ${esc((a.patients&&a.patients.full_name||'—').split(' ')[0])}
                </div>`;
              }).join('')}
            </div>`;
          }).join('')}
        `).join('')}
      </div>
    </div>`;
  };

  return `<div class="page" style="display:flex;flex-direction:column;gap:14px;height:calc(100vh - 56px);overflow:hidden;padding:16px">
    <!-- Tooltip -->
    <div id="cal-tooltip" style="display:none;position:fixed;top:0;left:0;z-index:1000;background:var(--navy);color:#fff;padding:10px 14px;border-radius:10px;font-size:12px;line-height:1.6;pointer-events:none;max-width:240px;box-shadow:var(--shadow-lg)"></div>

    <!-- Toolbar -->
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;flex-shrink:0">
      <!-- Date nav -->
      <button class="btn btn-ghost btn-sm" data-cal-nav="-1">‹</button>
      <span style="font-size:13px;font-weight:500;min-width:200px;text-align:center">${calView==='day'?dateStr:
        `${weekStart.toLocaleDateString('el-GR',{day:'numeric',month:'short'})} – ${new Date(weekStart.getTime()+6*86400000).toLocaleDateString('el-GR',{day:'numeric',month:'short',year:'numeric'})}`
      }</span>
      <button class="btn btn-ghost btn-sm" data-cal-nav="1">›</button>
      <button class="btn btn-ghost btn-sm" data-cal-today>Σήμερα</button>

      <div style="flex:1"></div>

      <!-- View mode -->
      <div style="display:flex;border:1px solid var(--border);border-radius:8px;overflow:hidden">
        <button class="btn btn-sm" style="border-radius:0;background:${calView==='day'?'var(--blue)':'transparent'};color:${calView==='day'?'#fff':'var(--text-2)'}" data-cal-view="day">Ημέρα</button>
        <button class="btn btn-sm" style="border-radius:0;background:${calView==='week'?'var(--blue)':'transparent'};color:${calView==='week'?'#fff':'var(--text-2)'};border-left:1px solid var(--border)" data-cal-view="week">Εβδομάδα</button>
      </div>

      <!-- Column mode -->
      <div style="display:flex;border:1px solid var(--border);border-radius:8px;overflow:hidden">
        <button class="btn btn-sm" style="border-radius:0;background:${calMode==='therapist'?'var(--blue)':'transparent'};color:${calMode==='therapist'?'#fff':'var(--text-2)'}" data-cal-mode="therapist">Θεραπευτές</button>
        <button class="btn btn-sm" style="border-radius:0;background:${calMode==='room'?'var(--blue)':'transparent'};color:${calMode==='room'?'#fff':'var(--text-2)'};border-left:1px solid var(--border)" data-cal-mode="room">Δωμάτια</button>
      </div>

      <button class="btn btn-primary btn-sm" data-modal="new-appt">+ Ραντεβού</button>
    </div>

    <!-- Legend -->
    <div style="display:flex;gap:10px;flex-wrap:wrap;flex-shrink:0;font-size:11px">
      ${[['#534AB7','#EEEDFE','VIP'],['#1D9E75','#E1F5EE','Ολοκληρώθηκε'],['#2B3BF0','#E6F1FB','Επιβεβαιωμένο'],['#EF9F27','#FAEEDA','Εκκρεμεί'],['#D85A30','#FAECE7','Ακυρώθηκε']].map(([c,bg,l])=>`
      <div style="display:flex;align-items:center;gap:4px">
        <div style="width:10px;height:10px;border-radius:2px;background:${bg};border-left:3px solid ${c}"></div>
        <span style="color:var(--text-2)">${l}</span>
      </div>`).join('')}
      <div style="display:flex;align-items:center;gap:4px"><span style="color:#D85A30">⚠</span><span style="color:var(--text-2)">Χωρίς GDPR</span></div>
      <div style="display:flex;align-items:center;gap:4px"><span style="color:#534AB7">★</span><span style="color:var(--text-2)">VIP</span></div>
    </div>

    <!-- Calendar grid -->
    <div style="flex:1;overflow:auto">
      ${calView==='day' ? renderDayView() : renderWeekView()}
    </div>

    <!-- Appointment detail panel -->
    <div id="appt-detail-panel" style="display:none;position:fixed;right:20px;top:80px;width:320px;background:var(--white);border-radius:14px;box-shadow:var(--shadow-lg);border:1px solid var(--border-2);z-index:500;padding:20px">
      <div style="display:flex;justify-content:space-between;margin-bottom:14px">
        <span style="font-size:14px;font-weight:600">Ραντεβού</span>
        <button onclick="document.getElementById('appt-detail-panel').style.display='none'" style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--text-2)">×</button>
      </div>
      <div id="appt-detail-content"></div>
    </div>
  </div>`;
}

async function loadLaserForm(id) {
  S.laserFormId = id;
  S.page = 'laser-detail';
  await loadPageData();
}

const BODY_PARTS = ['Μασχάλες','Bikini','Brazilian','Πλήρες Bikini','Πόδια (ολόκληρα)','Μηροί','Γάμπες','Γόνατα','Χέρια (ολόκληρα)','Μπράτσα','Πήχεις','Πρόσωπο','Μουστάκι','Πηγούνι','Μάγουλα','Σβέρκος','Πλάτη','Ώμοι','Στήθος','Κοιλιά','Γλουτοί','Αυχένας'];
const SKIN_TYPES_LIST = ['I','II','III','IV','V','VI'];
const HAIR_COLORS_LIST = ['Μαύρο','Σανφό','Γκρι','Καφέ','Κόκκινο'];
const BRAND_PINK = '#C4618A';
let _laserBodyParts = [];
let _laserRegions = [];

function renderLaserDetail() {
  const f = S.laserFormDetail;
  if (!f) return '<div class="page"><div class="empty-state"><div>Φόρτωση...</div></div></div>';
  const ms = f.machine_settings||{};
  const regions = ms.regions||Array(4).fill(null).map(()=>({body_part:'',sessions:Array(6).fill(null).map(()=>({date:'',spot_size:'',energy:'',dcd:'',notes:''})),notes:''}));
  _laserBodyParts = [...(f.body_parts||[])];
  _laserRegions = JSON.parse(JSON.stringify(regions));

  const FRONT_ZONES = [
    {id:'Πρόσωπο',x:50,y:7},{id:'Αυχένας',x:50,y:13},{id:'Στήθος',x:50,y:23},
    {id:'Μασχάλες',x:28,y:21},{id:'Κοιλιά',x:50,y:34},{id:'Bikini',x:50,y:46},
    {id:'Μπράτσα',x:20,y:28},{id:'Πήχεις',x:16,y:40},{id:'Μηροί',x:42,y:57},
    {id:'Γάμπες',x:42,y:74},{id:'Γόνατα',x:42,y:66},
  ];
  const BACK_ZONES = [
    {id:'Σβέρκος',x:50,y:10},{id:'Ώμοι',x:33,y:17},{id:'Πλάτη',x:50,y:25},
    {id:'Γλουτοί',x:50,y:47},{id:'Μουστάκι',x:50,y:10},
  ];

  const bodySvg = (zones, label) => `
    <div style="text-align:center">
      <div style="font-size:9px;font-weight:700;color:#C4618A;letter-spacing:1px;margin-bottom:4px;text-transform:uppercase">${label}</div>
      <div style="position:relative;width:90px;height:180px;margin:0 auto">
        <svg viewBox="0 0 100 200" width="90" height="180" style="position:absolute;inset:0">
          <ellipse cx="50" cy="9" rx="10" ry="9" fill="#f0d5c8" stroke="#dbb8a8" stroke-width="0.8"/>
          <rect x="36" y="18" width="28" height="5" rx="2" fill="#f0d5c8" stroke="#dbb8a8" stroke-width="0.8"/>
          <rect x="30" y="23" width="40" height="48" rx="8" fill="#f0d5c8" stroke="#dbb8a8" stroke-width="0.8"/>
          <rect x="12" y="23" width="18" height="42" rx="6" fill="#f0d5c8" stroke="#dbb8a8" stroke-width="0.8"/>
          <rect x="70" y="23" width="18" height="42" rx="6" fill="#f0d5c8" stroke="#dbb8a8" stroke-width="0.8"/>
          <rect x="32" y="69" width="16" height="60" rx="6" fill="#f0d5c8" stroke="#dbb8a8" stroke-width="0.8"/>
          <rect x="52" y="69" width="16" height="60" rx="6" fill="#f0d5c8" stroke="#dbb8a8" stroke-width="0.8"/>
        </svg>
        ${zones.map(z=>{
          const sel = _laserBodyParts.includes(z.id);
          return `<div title="${z.id}" style="position:absolute;left:${z.x}%;top:${z.y}%;transform:translate(-50%,-50%);width:${sel?14:8}px;height:${sel?14:8}px;border-radius:50%;background:${sel?'#C4618A':'rgba(196,97,138,0.2)'};border:1.5px solid ${sel?'#C4618A':'rgba(196,97,138,0.4)'};cursor:pointer;z-index:2;transition:.15s" onclick="toggleBodyPart('${z.id}')"></div>`;
        }).join('')}
      </div>
    </div>`;

  return `<div class="page">
    <!-- Header -->
    <div style="background:linear-gradient(135deg,#C4618A,#e891b5);padding:16px 24px;border-radius:12px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center">
      <div>
        <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.7);letter-spacing:1px;text-transform:uppercase">${esc(S.clinic&&S.clinic.name||'medi360')}</div>
        <div style="font-size:16px;font-weight:700;color:#fff;margin-top:2px">ΚΑΡΤΕΛΑ ΠΕΛΑΤΗ - LASER ΑΠΟΤΡΙΧΩΣΗΣ</div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" data-page="laser" style="background:rgba(255,255,255,0.15);color:#fff;border-color:rgba(255,255,255,0.3)">← Πίσω</button>
        <button class="btn btn-ghost btn-sm" onclick="window.print()" style="background:rgba(255,255,255,0.15);color:#fff;border-color:rgba(255,255,255,0.3)">🖨 Εκτύπωση</button>
        <button class="btn btn-sm" id="save-laser-form" style="background:#fff;color:#C4618A;font-weight:600">💾 Αποθήκευση</button>
      </div>
    </div>

    <!-- Patient info -->
    <div class="card" style="padding:20px;margin-bottom:16px;border-top:3px solid #C4618A">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:16px;align-items:start">
        <div>
          <div style="font-size:10px;font-weight:600;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Ονοματεπώνυμο</div>
          <div style="font-size:14px;font-weight:600">${esc(f.patients&&f.patients.full_name||'—')}</div>
          <div style="font-size:11px;color:var(--text-2)">${esc(f.patients&&f.patients.phone||'')}</div>
        </div>
        <div>
          <div style="font-size:10px;font-weight:600;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Φύλο</div>
          <div style="display:flex;gap:12px;margin-top:4px">
            <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer">
              <input type="radio" name="lf-gender" value="female" ${f.gender==='female'?'checked':''} onchange="if(S.laserFormDetail)S.laserFormDetail.gender='female'"/> Γυναίκα
            </label>
            <label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer">
              <input type="radio" name="lf-gender" value="male" ${f.gender==='male'?'checked':''} onchange="if(S.laserFormDetail)S.laserFormDetail.gender='male'"/> Άνδρας
            </label>
          </div>
        </div>
        <div>
          <div style="font-size:10px;font-weight:600;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">Φωτότυπος Δέρματος</div>
          <div style="display:flex;gap:4px">
            ${SKIN_TYPES_LIST.map((st,i)=>`<div onclick="selectSkinType('${st}')" id="st-${st}" style="width:24px;height:24px;border-radius:50%;background:${['#F5DCCC','#E8C4A0','#D4A87A','#B8865A','#8B5E3C','#4A2C1A'][i]};cursor:pointer;border:2px solid ${f.skin_type===st?'#C4618A':'transparent'};display:flex;align-items:center;justify-content:center;font-size:8px;color:${i>2?'#fff':'#333'};font-weight:700" title="${st}">${st}</div>`).join('')}
          </div>
        </div>
        <div>
          <div style="font-size:10px;font-weight:600;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Χρώμα Τριχός</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px">
            ${HAIR_COLORS_LIST.map(h=>`<label style="display:flex;align-items:center;gap:5px;font-size:11px;cursor:pointer">
              <input type="checkbox" ${(ms.hair_colors||[ms.hair_color]).includes(h)?'checked':''} value="${h}" class="lf-hair-color"/> ${h}
            </label>`).join('')}
          </div>
        </div>
      </div>
      <div style="display:flex;gap:16px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border-2);align-items:center">
        <div>
          <div style="font-size:10px;font-weight:600;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Ημ. Έναρξης</div>
          <input type="date" id="start-date" value="${ms.start_date||''}" style="font-size:12px;padding:4px 8px;border-radius:6px;border:1px solid var(--border);width:130px"/>
        </div>
        <div>
          <div style="font-size:10px;font-weight:600;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Operator</div>
          <input type="text" id="lf-operator" value="${esc(ms.operator||S.profile&&S.profile.full_name||'')}" style="font-size:12px;padding:4px 8px;border-radius:6px;border:1px solid var(--border);width:160px" placeholder="Όνομα θεραπευτή"/>
        </div>
        <div style="display:flex;align-items:center;gap:6px;margin-top:16px">
          <input type="checkbox" id="consent-signed" ${f.consent_signed?'checked':''} style="width:16px;height:16px;accent-color:#C4618A"/>
          <label for="consent-signed" style="font-size:12px;font-weight:500;cursor:pointer;color:#C4618A">Συναίνεση υπογεγραμμένη</label>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:200px 1fr;gap:16px;margin-bottom:16px">
      <!-- Body map -->
      <div class="card" style="padding:16px">
        <div style="font-size:11px;font-weight:700;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;text-align:center">ΧΑΡΤΗΣ ΣΩΜΑΤΟΣ <span style="color:var(--text-2);font-weight:400">(${_laserBodyParts.length} περιοχές)</span></div>
        <div style="display:flex;justify-content:space-around">
          ${bodySvg(FRONT_ZONES,'ΜΠΡΟΣΤΑ')}
          ${bodySvg(BACK_ZONES,'ΠΙΣΩ')}
        </div>
        <div style="margin-top:12px;display:flex;flex-wrap:wrap;gap:4px;justify-content:center">
          ${BODY_PARTS.map(bp=>`<div onclick="toggleBodyPart('${esc(bp)}')" id="bp-${bp.replace(/[^a-zA-Zα-ωΑ-Ω]/g,'_')}" style="font-size:9px;padding:2px 7px;border-radius:99px;cursor:pointer;border:1px solid ${_laserBodyParts.includes(bp)?'#C4618A':'var(--border)'};background:${_laserBodyParts.includes(bp)?'#F5E8EF':'transparent'};color:${_laserBodyParts.includes(bp)?'#C4618A':'var(--text-2)'};transition:.12s">${esc(bp)}</div>`).join('')}
        </div>
      </div>

      <!-- Regions -->
      <div>
        <div style="font-size:11px;font-weight:700;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">ΠΙΝΑΚΕΣ ΘΕΡΑΠΕΙΑΣ <span style="font-size:10px;font-weight:400;color:var(--text-2)">(επιλέξτε περιοχή για να εμφανιστεί στο γραφικό)</span></div>
        <div id="regions-container" style="display:flex;flex-direction:column;gap:12px">
          ${regions.map((r,ri)=>`
          <div style="border:1.5px solid ${ri<2?'#C4618A':'#e8b4ca'};border-radius:10px;overflow:hidden">
            <div style="background:${ri<2?'#C4618A':'#e8b4ca'};padding:10px 14px;display:flex;align-items:center;gap:10px">
              <span style="font-size:11px;font-weight:700;color:#fff;text-transform:uppercase">ΠΕΡΙΟΧΗ ${ri+1}:</span>
              <select onchange="updateRegionPart(${ri},this.value)" style="flex:1;font-size:12px;padding:4px 8px;border-radius:6px;border:none;background:rgba(255,255,255,0.9);color:#C4618A;font-weight:500">
                <option value="">-- Επιλέξτε περιοχή --</option>
                ${BODY_PARTS.map(bp=>`<option value="${bp}" ${r.body_part===bp?'selected':''}>${bp}</option>`).join('')}
              </select>
            </div>
            <div style="overflow-x:auto">
              <table style="width:100%;border-collapse:collapse;font-size:11px">
                <thead><tr style="background:#FDF0F5">
                  <th style="padding:8px 10px;text-align:center;color:#C4618A;font-weight:600;width:40px">Α/Α</th>
                  <th style="padding:8px 10px;text-align:center;color:#C4618A;font-weight:600">Ημ/νία</th>
                  <th style="padding:8px 10px;text-align:center;color:#C4618A;font-weight:600">Spot Size</th>
                  <th style="padding:8px 10px;text-align:center;color:#C4618A;font-weight:600">Ενέργεια (j/cm²)</th>
                  <th style="padding:8px 10px;text-align:center;color:#C4618A;font-weight:600">DCD</th>
                  <th style="padding:8px 10px;text-align:left;color:#C4618A;font-weight:600">Παρατηρήσεις</th>
                </tr></thead>
                <tbody>
                  ${Array(6).fill(null).map((_,si)=>{
                    const s=(r.sessions&&r.sessions[si])||{};
                    return `<tr style="border-top:1px solid #FCE4EE">
                      <td style="padding:6px 10px;text-align:center;font-weight:600;color:#C4618A">${si+1}</td>
                      <td style="padding:4px 6px"><input type="date" value="${s.date||''}" onchange="updateSession(${ri},${si},'date',this.value)" style="font-size:11px;padding:3px 6px;border-radius:5px;border:1px solid #e8b4ca;width:100%;text-align:center"/></td>
                      <td style="padding:4px 6px"><input type="text" value="${esc(s.spot_size||'')}" placeholder="mm" onchange="updateSession(${ri},${si},'spot_size',this.value)" style="font-size:11px;padding:3px 6px;border-radius:5px;border:1px solid #e8b4ca;width:100%;text-align:center"/></td>
                      <td style="padding:4px 6px"><input type="text" value="${esc(s.energy||'')}" placeholder="j/cm²" onchange="updateSession(${ri},${si},'energy',this.value)" style="font-size:11px;padding:3px 6px;border-radius:5px;border:1px solid #e8b4ca;width:100%;text-align:center"/></td>
                      <td style="padding:4px 6px"><input type="text" value="${esc(s.dcd||'')}" placeholder="DCD" onchange="updateSession(${ri},${si},'dcd',this.value)" style="font-size:11px;padding:3px 6px;border-radius:5px;border:1px solid #e8b4ca;width:100%;text-align:center"/></td>
                      <td style="padding:4px 6px"><input type="text" value="${esc(s.notes||'')}" placeholder="..." onchange="updateSession(${ri},${si},'notes',this.value)" style="font-size:11px;padding:3px 6px;border-radius:5px;border:1px solid #e8b4ca;width:100%"/></td>
                    </tr>`;
                  }).join('')}
                </tbody>
              </table>
            </div>
          </div>`).join('')}
          <button class="btn btn-ghost btn-sm" onclick="addRegionRow()" style="border-color:#C4618A;color:#C4618A;align-self:flex-start">+ Προσθήκη Περιοχής</button>
        </div>
      </div>
    </div>

    <!-- General notes -->
    <div class="card" style="padding:16px;border-top:3px solid #C4618A">
      <div style="font-size:11px;font-weight:700;color:#C4618A;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">ΓΕΝΙΚΕΣ ΠΑΡΑΤΗΡΗΣΕΙΣ:</div>
      <textarea id="treatment-notes" rows="4" style="width:100%;font-size:13px;padding:12px;border:1px solid #e8b4ca;border-radius:8px;resize:vertical;font-family:var(--font)" placeholder="Σημειώσεις θεραπευτή, ιδιαιτερότητες, αντενδείξεις...">${esc(f.treatment_notes||'')}</textarea>
    </div>
  </div>`;
}

function toggleBodyPart(bp) {
  const idx = _laserBodyParts.indexOf(bp);
  if (idx>=0) _laserBodyParts.splice(idx,1); else _laserBodyParts.push(bp);
  const el = document.getElementById('bp-'+bp.replace(/[^a-zA-Zα-ωΑ-Ω]/g,'_'));
  if (el) {
    const on = _laserBodyParts.includes(bp);
    el.style.borderColor = on?BRAND_PINK:'var(--border)';
    el.style.background = on?'#F5E8EF':'transparent';
    el.style.color = on?BRAND_PINK:'var(--text-2)';
  }
}
function selectSkinType(st) {
  if (S.laserFormDetail) S.laserFormDetail.skin_type = st;
  SKIN_TYPES_LIST.forEach(s => { const el=document.getElementById('st-'+s); if(el) el.style.borderColor=s===st?'#1a1f3a':'transparent'; });
}
function updateRegionPart(ri,val) { if(_laserRegions[ri]) _laserRegions[ri].body_part=val; }
function updateSession(ri,si,field,val) { if(_laserRegions[ri]&&_laserRegions[ri].sessions&&_laserRegions[ri].sessions[si]) _laserRegions[ri].sessions[si][field]=val; }
function updateRegionNotes(ri,val) { if(_laserRegions[ri]) _laserRegions[ri].notes=val; }
function addRegionRow() {
  const newRow = {body_part:'',sessions:Array(7).fill(null).map(()=>({date:'',spot_size:''})),notes:''};
  _laserRegions.push(newRow);
  const ri = _laserRegions.length-1;
  const tbody = document.getElementById('regions-tbody');
  if (!tbody) return;
  const tr = document.createElement('tr');
  tr.style.borderTop = '1px solid var(--border-2)';
  tr.innerHTML = `<td style="padding:5px 8px"><select onchange="updateRegionPart(${ri},this.value)" style="font-size:10px;padding:2px 5px;border-radius:5px;border:1px solid var(--border);min-width:100px"><option value="">—</option>${BODY_PARTS.map(bp=>`<option value="${bp}">${bp}</option>`).join('')}</select></td>${[0,1,2,3,4,5,6].map(si=>`<td style="padding:3px 2px;text-align:center"><input type="date" onchange="updateSession(${ri},${si},'date',this.value)" style="font-size:9px;padding:1px 2px;border-radius:3px;border:1px solid var(--border);width:88px;display:block;margin-bottom:2px"/><input type="text" placeholder="J/cm²" onchange="updateSession(${ri},${si},'spot_size',this.value)" style="font-size:9px;padding:1px 4px;border-radius:3px;border:1px solid var(--border);width:44px"/></td>`).join('')}<td style="padding:3px 8px"><input type="text" placeholder="..." onchange="updateRegionNotes(${ri},this.value)" style="font-size:11px;padding:3px 6px;border-radius:5px;border:1px solid var(--border);width:100%"/></td>`;
  tbody.appendChild(tr);
}

const SMS_AUTOMATIONS = [
  {key:'sms1_info',label:'SMS 1 — Ενημέρωσης',desc:'Αμέσως μετά κλείσιμο ραντεβού',color:'#2B3BF0',bg:'#E6F1FB',tmpl:'Αγαπητέ/ή {name}, το ραντεβού σας στη {clinic} επιβεβαιώθηκε για {date} στις {time}.'},
  {key:'sms2_confirm',label:'SMS 2 — Επιβεβαίωσης',desc:'3 μέρες πριν το ραντεβού',color:'#1D9E75',bg:'#E1F5EE',tmpl:'Αγαπητέ/ή {name}, υπενθυμίζουμε το ραντεβού σας στη {clinic} για {date} στις {time}. Επιβεβαιώστε: {confirm_link}'},
  {key:'sms3_warning',label:'SMS 3 — Προειδοποίησης',desc:'Αν δεν επιβεβαιώθηκε',color:'#EF9F27',bg:'#FAEEDA',tmpl:'Αγαπητέ/ή {name}, το ραντεβού σας στη {clinic} για {date} δεν έχει επιβεβαιωθεί.'},
  {key:'sms4_cancel',label:'SMS 4 — Ακύρωσης',desc:'Ακύρωση αν δεν επιβεβαιώθηκε',color:'#D85A30',bg:'#FAECE7',tmpl:'Αγαπητέ/ή {name}, το ραντεβού σας στη {clinic} για {date} ακυρώθηκε λόγω μη επιβεβαίωσης.'},
  {key:'google_review',label:'Google Review',desc:'Μετά ολοκλήρωση ραντεβού',color:'#534AB7',bg:'#EEEDFE',tmpl:'Αγαπητέ/ή {name}, ευχαριστούμε για την επίσκεψή σας! Αξιολογήστε μας: {review_link}'},
  {key:'health_history',label:'Health History',desc:'Για νέους ασθενείς',color:'#185FA5',bg:'#E6F1FB',tmpl:'Αγαπητέ/ή {name}, παρακαλούμε συμπληρώστε το ιατρικό σας ιστορικό: {history_link}'},
];

function renderSms() {
  const cid = clinicId();
  if (!cid) return '<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div>Επίλεξε κλινική</div></div></div>';
  const log = S.smsLog||[];
  const smsTab = S.smsTab||'automations';
  return `<div class="page">
    <div class="page-header"><h1 class="page-title">SMS & Αυτοματισμοί</h1></div>
    <div style="display:flex;gap:0;border-bottom:1px solid var(--border-2);margin-bottom:20px">
      ${['automations','log'].map(t=>`<button class="btn" style="border-radius:0;border-bottom:2px solid ${smsTab===t?'var(--blue)':'transparent'};color:${smsTab===t?'var(--blue)':'var(--text-2)'};background:transparent;padding:8px 16px;font-size:12px" data-sms-tab="${t}">${t==='automations'?'Αυτοματισμοί':'SMS Log'}</button>`).join('')}
    </div>
    ${smsTab==='automations'?`
    <div style="display:flex;flex-direction:column;gap:12px">
      ${SMS_AUTOMATIONS.map(a=>`<div class="card" style="padding:16px">
        <div style="display:flex;align-items:center;gap:12px">
          <div style="width:36px;height:36px;border-radius:8px;background:${a.bg};display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">✉</div>
          <div style="flex:1">
            <div style="font-size:13px;font-weight:500;color:${a.color}">${a.label}</div>
            <div style="font-size:11px;color:var(--text-2)">${a.desc}</div>
          </div>
          <div style="display:flex;align-items:center;gap:6px">
            <span style="font-size:11px;color:var(--text-2)">Ενεργό</span>
            <div style="width:32px;height:18px;border-radius:9px;background:var(--blue);position:relative;cursor:pointer">
              <div style="width:14px;height:14px;border-radius:50%;background:#fff;position:absolute;right:2px;top:2px"></div>
            </div>
          </div>
        </div>
        <div style="margin-top:12px;padding:10px;background:var(--surface);border-radius:8px;font-size:12px;color:var(--text-2);font-family:var(--mono)">${esc(a.tmpl)}</div>
      </div>`).join('')}
    </div>`:`
    <div class="card">
      <div class="table-wrap"><table>
        <thead><tr><th>Ασθενής</th><th>Τύπος</th><th>Τηλέφωνο</th><th>Κατάσταση</th><th>Ημ/νία</th></tr></thead>
        <tbody>${log.length?log.map(l=>`<tr>
          <td style="font-weight:500">${esc((l.patients&&l.patients.full_name)||'—')}</td>
          <td>${badge(l.sms_type||'—','#E6F1FB','#185FA5')}</td>
          <td style="font-family:var(--mono);font-size:12px;color:var(--text-2)">${esc(l.phone||'—')}</td>
          <td>${l.status==='sent'?badge('Στάλθηκε','#E1F5EE','#0F6E56'):badge('Σφάλμα','#FCEBEB','#A32D2D')}</td>
          <td style="font-size:12px;color:var(--text-2)">${fmt(l.sent_at)}</td>
        </tr>`).join(''):`<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">✉</div><div>Δεν υπάρχουν SMS ακόμα</div></div></td></tr>`}
        </tbody>
      </table></div>
    </div>`}
  </div>`;
}

// ── CONSENTS ──
function renderConsents() {
  const cid = clinicId();
  if (!cid) return '<div class="page"><div class="empty-state"><div class="empty-icon">⊞</div><div>Επίλεξε κλινική</div></div></div>';
  const conTab = S.conTab||'gdpr';
  const gdpr = S.gdprConsents||[];
  const svc = S.serviceConsents||[];
  const tmpl = S.consentTemplates||[];
  const integrations = (S.clinic&&S.clinic.integrations)||{};
  const gdprFormLink = integrations.gdpr_form_link || 'https://docs.google.com/forms/d/e/1FAIpQLSe5XiCNxnDOYMxgUbzlOP8G8ZDe-R3VBaJPlZeM1gthPElHiA/viewform?usp=header';
  const consultFormLink = integrations.consultation_form_link || 'https://docs.google.com/forms/d/e/1FAIpQLSctJ9i3x26jEpvCqIGLxts-YEK_7q9um64mLwtst_4-dkaXAg/viewform?usp=header';
  return `<div class="page">
    <div class="page-header">
      <div><h1 class="page-title">Συναινέσεις & Φόρμες</h1></div>
      ${conTab==='templates'?`<button class="btn btn-primary" data-modal="new-consent-tmpl">+ Νέο Template</button>`:''}
    </div>
    <!-- Form cards -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px">
      <div class="card" style="padding:20px;border-left:4px solid #2B3BF0">
        <div style="font-size:14px;font-weight:600;color:var(--navy);margin-bottom:4px">🏥 Ιατρικό Ιστορικό & GDPR</div>
        <div style="font-size:12px;color:var(--text-2);margin-bottom:12px;line-height:1.5">Φόρμα ιατρικού ιστορικού, αλλεργιών και GDPR. Αποστείλετε πριν την πρώτη επίσκεψη.</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
          <a href="${gdprFormLink}" target="_blank" class="btn btn-primary btn-sm">🔗 Άνοιγμα Φόρμας</a>
          <button class="btn btn-ghost btn-sm" onclick="copyToClipboard('${gdprFormLink}','gdpr-copy-msg')">📋 Αντιγραφή</button>
          <button class="btn btn-ghost btn-sm" onclick="openSmsModal('${gdprFormLink}','Ιατρικό Ιστορικό & GDPR')">📱 SMS</button>
        </div>
        <div id="gdpr-copy-msg" style="font-size:11px;color:#0F6E56;display:none">✓ Αντιγράφηκε!</div>
        <div style="padding:8px 10px;background:var(--surface);border-radius:6px;font-size:10px;color:var(--text-3);font-family:var(--mono);word-break:break-all">${gdprFormLink}</div>
        <div style="margin-top:8px"><button class="btn btn-ghost btn-xs" onclick="toggleQR('gdpr-qr','${gdprFormLink}')">QR Code</button></div>
        <div id="gdpr-qr" style="display:none;text-align:center;margin-top:8px"></div>
      </div>
      <div class="card" style="padding:20px;border-left:4px solid #534AB7">
        <div style="font-size:14px;font-weight:600;color:var(--navy);margin-bottom:4px">📋 Consultation</div>
        <div style="font-size:12px;color:var(--text-2);margin-bottom:12px;line-height:1.5">Φόρμα consultation. Αποστείλετε πριν από consultation session ή αισθητική θεραπεία.</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
          <a href="${consultFormLink}" target="_blank" class="btn btn-primary btn-sm" style="background:#534AB7">🔗 Άνοιγμα Φόρμας</a>
          <button class="btn btn-ghost btn-sm" onclick="copyToClipboard('${consultFormLink}','consult-copy-msg')">📋 Αντιγραφή</button>
          <button class="btn btn-ghost btn-sm" onclick="openSmsModal('${consultFormLink}','Consultation')">📱 SMS</button>
        </div>
        <div id="consult-copy-msg" style="font-size:11px;color:#0F6E56;display:none">✓ Αντιγράφηκε!</div>
        <div style="padding:8px 10px;background:var(--surface);border-radius:6px;font-size:10px;color:var(--text-3);font-family:var(--mono);word-break:break-all">${consultFormLink}</div>
        <div style="margin-top:8px"><button class="btn btn-ghost btn-xs" onclick="toggleQR('consult-qr','${consultFormLink}')">QR Code</button></div>
        <div id="consult-qr" style="display:none;text-align:center;margin-top:8px"></div>
      </div>
    </div>
    <!-- SMS Modal -->
    <div id="sms-link-modal" style="display:none;position:fixed;inset:0;background:rgba(10,12,24,0.5);backdrop-filter:blur(3px);z-index:300;align-items:center;justify-content:center;padding:16px">
      <div style="background:var(--white);border-radius:16px;padding:24px;max-width:400px;width:100%;box-shadow:var(--shadow-lg)">
        <div style="font-size:15px;font-weight:600;margin-bottom:14px" id="sms-modal-title">Αποστολή SMS</div>
        <div class="form-group"><label class="form-label">Τηλέφωνο παραλήπτη</label><input id="sms-link-phone" placeholder="69XXXXXXXX" type="tel"/></div>
        <div class="form-group"><label class="form-label">Μήνυμα</label><textarea id="sms-link-text" rows="4" style="width:100%;font-size:12px;padding:10px;border:1px solid var(--border);border-radius:8px;resize:vertical"></textarea></div>
        <div style="font-size:11px;color:var(--text-2);margin-bottom:14px">Η αποστολή γίνεται μέσω του SMS provider της κλινικής</div>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button class="btn btn-ghost" onclick="document.getElementById('sms-link-modal').style.display='none'">Ακύρωση</button>
          <button class="btn btn-primary" onclick="document.getElementById('sms-link-modal').style.display='none';alert('SMS σύντομα διαθέσιμο μέσω SMS provider')">Αποστολή</button>
        </div>
      </div>
    </div>
    <!-- Tabs -->
    <div style="display:flex;gap:0;border-bottom:1px solid var(--border-2);margin-bottom:20px">
      ${[{id:'gdpr',l:`GDPR (${gdpr.length})`},{id:'service',l:`Υπηρεσιών (${svc.length})`},{id:'templates',l:'Templates'}].map(t=>`<button class="btn" style="border-radius:0;border-bottom:2px solid ${conTab===t.id?'var(--blue)':'transparent'};color:${conTab===t.id?'var(--blue)':'var(--text-2)'};background:transparent;padding:8px 16px;font-size:12px" data-con-tab="${t.id}">${t.l}</button>`).join('')}
    </div>
    ${conTab==='gdpr'?`<div class="card"><div class="table-wrap"><table>
      <thead><tr><th>Ασθενής</th><th>Τηλέφωνο</th><th>Υπογραφή</th><th>Ημ/νία</th><th></th></tr></thead>
      <tbody>${gdpr.length?gdpr.map(c=>`<tr>
        <td style="font-weight:500;cursor:pointer" ${c.patients?`data-patient="${c.patients.id}"`:''}>${esc((c.patients&&c.patients.full_name)||'—')}</td>
        <td style="font-family:var(--mono);font-size:12px;color:var(--text-2)">${esc((c.patients&&c.patients.phone)||'—')}</td>
        <td>${c.signed?badge('✓ Υπογεγραμμένο','#E1F5EE','#0F6E56'):badge('Εκκρεμεί','#FAEEDA','#854F0B')}</td>
        <td style="font-size:12px;color:var(--text-2)">${fmt(c.signed_at)}</td>
        <td><a href="${gdprFormLink}" target="_blank" class="btn btn-ghost btn-xs">🔗</a></td>
      </tr>`).join(''):`<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">✓</div><div style="margin-bottom:10px">Δεν υπάρχουν GDPR συναινέσεις</div><a href="${gdprFormLink}" target="_blank" class="btn btn-primary btn-sm">🔗 Φόρμα GDPR</a></div></td></tr>`}
      </tbody></table></div></div>`:''}
    ${conTab==='service'?`<div class="card"><div class="table-wrap"><table>
      <thead><tr><th>Ασθενής</th><th>Υπηρεσία</th><th>Κατάσταση</th><th>Ημ/νία</th><th></th></tr></thead>
      <tbody>${svc.length?svc.map(c=>`<tr>
        <td style="font-weight:500">${esc((c.patients&&c.patients.full_name)||'—')}</td>
        <td>${badge(c.service_name||'—','#E6F1FB','#185FA5')}</td>
        <td>${c.signed?badge('✓ Υπογεγραμμένο','#E1F5EE','#0F6E56'):badge('Εκκρεμεί','#FAEEDA','#854F0B')}</td>
        <td style="font-size:12px;color:var(--text-2)">${fmt(c.signed_at)}</td>
        <td><a href="${consultFormLink}" target="_blank" class="btn btn-ghost btn-xs">🔗</a></td>
      </tr>`).join(''):`<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">📋</div><div style="margin-bottom:10px">Δεν υπάρχουν συναινέσεις</div><a href="${consultFormLink}" target="_blank" class="btn btn-primary btn-sm" style="background:#534AB7">🔗 Φόρμα Consultation</a></div></td></tr>`}
      </tbody></table></div></div>`:''}
    ${conTab==='templates'?`<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      ${tmpl.map(t=>`<div class="card" style="padding:16px">
        <div style="font-size:13px;font-weight:500;margin-bottom:6px">${esc(t.service_name)}</div>
        <div style="font-size:12px;color:var(--text-2);line-height:1.5;max-height:80px;overflow:hidden">${esc(t.consent_text&&t.consent_text.slice(0,150))}${(t.consent_text&&t.consent_text.length)>150?'...':''}</div>
        <div style="margin-top:10px;display:flex;justify-content:flex-end"><button class="btn btn-danger btn-xs" data-del-tmpl="${t.id}">Διαγραφή</button></div>
      </div>`).join('')||`<div class="empty-state"><div class="empty-icon">📄</div><div>Δεν υπάρχουν templates</div></div>`}
    </div>`:''}
  </div>`;
}

// ── SETTINGS ──
function renderSettings() {
  const cid = clinicId();
  const c = S.clinic;
  const integrations = (c&&c.integrations)||{};
  const settingsTab = S.settingsTab||'clinic';
  return `<div class="page">
    <div class="page-header"><h1 class="page-title">Ρυθμίσεις</h1></div>

    <!-- Tabs -->
    <div style="display:flex;gap:0;border-bottom:1px solid var(--border-2);margin-bottom:20px">
      ${[{id:'clinic',l:'Κλινική'},{id:'integrations',l:'Συνδέσεις'},{id:'import',l:'Εισαγωγή'},{id:'users',l:'Χρήστες'},{id:'account',l:'Λογαριασμός'}].map(t=>`
      <button class="btn" style="border-radius:0;border-bottom:2px solid ${settingsTab===t.id?'var(--blue)':'transparent'};color:${settingsTab===t.id?'var(--blue)':'var(--text-2)'};background:transparent;padding:8px 16px;font-size:13px" data-settings-tab="${t.id}">${t.l}</button>`).join('')}
    </div>

    <!-- CLINIC TAB -->
    ${settingsTab==='clinic'?`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px" class="dash-grid">
      <div class="card">
        <div class="card-header"><span class="card-title">Πληροφορίες Κλινικής</span></div>
        <div style="padding:16px">
          ${c?[['Όνομα',c.name],['Email',c.email],['Τηλέφωνο',c.phone],['Πόλη',c.city],['Διεύθυνση',c.address],['Ωράριο',c.settings&&c.settings.hours||'09:00 - 20:00']].map(([k,v])=>`
          <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-2);font-size:13px">
            <span style="color:var(--text-2)">${k}</span><span style="font-weight:500">${esc(v||'—')}</span>
          </div>`).join(''):'<div style="padding:20px;text-align:center;color:var(--text-2)">Δεν έχει επιλεγεί κλινική</div>'}
        </div>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">Ωράριο Λειτουργίας</span></div>
        <div style="padding:16px">
          <div class="form-group">
            <label class="form-label">Ώρα Έναρξης</label>
            <input type="time" id="clinic-start" value="${c&&c.settings&&c.settings.start_hour?String(c.settings.start_hour).padStart(2,'0')+':00':'09:00'}" style="max-width:140px"/>
          </div>
          <div class="form-group">
            <label class="form-label">Ώρα Λήξης</label>
            <input type="time" id="clinic-end" value="${c&&c.settings&&c.settings.end_hour?String(c.settings.end_hour).padStart(2,'0')+':00':'20:00'}" style="max-width:140px"/>
          </div>
          <div class="form-group">
            <label class="form-label">Slot Ραντεβού</label>
            <select id="clinic-slot" style="max-width:140px">
              ${[15,20,30,60].map(m=>`<option value="${m}" ${c&&c.settings&&c.settings.slot_minutes===m?'selected':''}>${m} λεπτά</option>`).join('')}
            </select>
          </div>
          <button class="btn btn-primary" id="save-clinic-settings">Αποθήκευση</button>
        </div>
      </div>
    </div>`:''}

    <!-- INTEGRATIONS TAB -->
    ${settingsTab==='integrations'?`
    <div style="display:flex;flex-direction:column;gap:16px">

      <!-- Google Sheets GDPR -->
      <div class="card">
        <div class="card-header">
          <div>
            <span class="card-title">📊 Google Sheets — Ιατρικό Ιστορικό & GDPR</span>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">Φόρμα συναίνεσης & ιατρικού ιστορικού</div>
          </div>
          ${integrations.gdpr_sheet_id?`<span class="badge badge-green">✓ Συνδεδεμένο</span>`:`<span class="badge badge-gray">Μη συνδεδεμένο</span>`}
        </div>
        <div style="padding:16px">
          <div class="form-group">
            <label class="form-label">Google Sheet ID ή URL</label>
            <input id="gdpr-sheet-id" placeholder="https://docs.google.com/spreadsheets/d/..." value="${esc(integrations.gdpr_sheet_id||'')}" style="font-family:var(--mono);font-size:12px"/>
            <div style="font-size:11px;color:var(--text-2);margin-top:4px">Το Sheet πρέπει να είναι κοινόχρηστο ως "Anyone with the link can view"</div>
          </div>
          <div class="form-group">
            <label class="form-label">Tab/Sheet Name (προαιρετικό)</label>
            <input id="gdpr-sheet-tab" placeholder="π.χ. Νέα Ιστορικά" value="${esc(integrations.gdpr_sheet_tab||'')}"/>
          </div>
          <div style="display:flex;gap:8px">
            <button class="btn btn-primary btn-sm" id="save-gdpr-sheet">Αποθήκευση</button>
            <button class="btn btn-ghost btn-sm" id="test-gdpr-sheet">🔄 Test σύνδεση</button>
          </div>
          <div id="gdpr-sheet-result" style="margin-top:10px;font-size:12px"></div>
        </div>
      </div>

      <!-- Google Sheets Consultation -->
      <div class="card">
        <div class="card-header">
          <div>
            <span class="card-title">📊 Google Sheets — Consultation</span>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">Φόρμα consultation</div>
          </div>
          ${integrations.consultation_sheet_id?`<span class="badge badge-green">✓ Συνδεδεμένο</span>`:`<span class="badge badge-gray">Μη συνδεδεμένο</span>`}
        </div>
        <div style="padding:16px">
          <div class="form-group">
            <label class="form-label">Google Sheet ID ή URL</label>
            <input id="consult-sheet-id" placeholder="https://docs.google.com/spreadsheets/d/..." value="${esc(integrations.consultation_sheet_id||'')}" style="font-family:var(--mono);font-size:12px"/>
          </div>
          <div class="form-group">
            <label class="form-label">Tab/Sheet Name (προαιρετικό)</label>
            <input id="consult-sheet-tab" placeholder="π.χ. Form Responses" value="${esc(integrations.consultation_sheet_tab||'')}"/>
          </div>
          <div style="display:flex;gap:8px">
            <button class="btn btn-primary btn-sm" id="save-consult-sheet">Αποθήκευση</button>
            <button class="btn btn-ghost btn-sm" id="test-consult-sheet">🔄 Test σύνδεση</button>
          </div>
          <div id="consult-sheet-result" style="margin-top:10px;font-size:12px"></div>
        </div>
      </div>

      <!-- Booking247 -->
      <div class="card">
        <div class="card-header">
          <div>
            <span class="card-title">📅 Booking247 — Email Sync</span>
            <div style="font-size:11px;color:var(--text-2);margin-top:2px">Αυτόματη εισαγωγή ραντεβού από emails</div>
          </div>
          <span class="badge badge-green">✓ Ενεργό</span>
        </div>
        <div style="padding:16px">
          <div style="background:#E1F5EE;border-radius:8px;padding:12px 14px;margin-bottom:14px;font-size:12px;color:#0F6E56">
            ✓ Τα emails από <strong>appointments@booking247.gr</strong> διαβάζονται αυτόματα και εισάγονται στο σύστημα.
          </div>
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <button class="btn btn-primary" id="sync-booking247-now">🔄 Sync τώρα</button>
            <button class="btn btn-ghost" id="sync-booking247-preview">👁 Προεπισκόπηση</button>
          </div>
          <div id="booking247-sync-result" style="margin-top:12px;font-size:12px"></div>
          <div id="booking247-preview-list" style="margin-top:12px"></div>
        </div>
      </div>
    </div>`:''}

    <!-- IMPORT TAB -->
    ${settingsTab==='import'?`
    <div style="display:flex;flex-direction:column;gap:16px">

      <!-- CSV Upload Patients -->
      <div class="card">
        <div class="card-header"><span class="card-title">📥 Εισαγωγή Πελατολογίου (CSV)</span></div>
        <div style="padding:16px">
          <div style="background:var(--surface);border-radius:8px;padding:12px;margin-bottom:14px;font-size:12px;color:var(--text-2)">
            <strong>Αναμενόμενες στήλες:</strong> Ονοματεπώνυμο, Τηλέφωνο, Email, Ημ.Γέννησης, Περιοχή<br>
            <strong>Delimiter:</strong> Κόμμα (,) · <strong>Encoding:</strong> UTF-8
          </div>
          <div id="csv-patients-drop" style="border:2px dashed var(--border);border-radius:10px;padding:32px;text-align:center;cursor:pointer;transition:.15s" onclick="document.getElementById('csv-patients-file').click()">
            <div style="font-size:24px;margin-bottom:8px">📄</div>
            <div style="font-size:13px;font-weight:500;margin-bottom:4px">Κλικ ή σύρε CSV αρχείο εδώ</div>
            <div style="font-size:11px;color:var(--text-2)">Υποστηρίζονται: .csv, .xlsx (μέσω Google Sheets export)</div>
          </div>
          <input type="file" id="csv-patients-file" accept=".csv,.txt" style="display:none"/>
          <div id="csv-patients-preview" style="margin-top:12px"></div>
          <div style="display:flex;gap:8px;margin-top:12px">
            <button class="btn btn-primary" id="import-patients-btn" style="display:none">📥 Εισαγωγή Ασθενών</button>
            <button class="btn btn-ghost" id="clear-patients-csv" style="display:none">✕ Καθαρισμός</button>
          </div>
          <div id="import-patients-result" style="margin-top:10px;font-size:12px"></div>
        </div>
      </div>

      <!-- CSV Upload Appointments -->
      <div class="card">
        <div class="card-header"><span class="card-title">📥 Εισαγωγή Ραντεβού (CSV)</span></div>
        <div style="padding:16px">
          <div style="background:var(--surface);border-radius:8px;padding:12px;margin-bottom:14px;font-size:12px;color:var(--text-2)">
            <strong>Αναμενόμενες στήλες:</strong> Τηλέφωνο/Ονοματεπώνυμο, Ημερομηνία, Ώρα, Υπηρεσία, Κατάσταση<br>
            <strong>Σύνδεση:</strong> με ασθενή μέσω τηλεφώνου
          </div>
          <div id="csv-appts-drop" style="border:2px dashed var(--border);border-radius:10px;padding:32px;text-align:center;cursor:pointer;transition:.15s" onclick="document.getElementById('csv-appts-file').click()">
            <div style="font-size:24px;margin-bottom:8px">📅</div>
            <div style="font-size:13px;font-weight:500;margin-bottom:4px">Κλικ ή σύρε CSV αρχείο εδώ</div>
            <div style="font-size:11px;color:var(--text-2)">Αρχεία ραντεβού από Booking247 ή άλλο σύστημα</div>
          </div>
          <input type="file" id="csv-appts-file" accept=".csv,.txt" style="display:none"/>
          <div id="csv-appts-preview" style="margin-top:12px"></div>
          <div style="display:flex;gap:8px;margin-top:12px">
            <button class="btn btn-primary" id="import-appts-btn" style="display:none">📥 Εισαγωγή Ραντεβού</button>
            <button class="btn btn-ghost" id="clear-appts-csv" style="display:none">✕ Καθαρισμός</button>
          </div>
          <div id="import-appts-result" style="margin-top:10px;font-size:12px"></div>
        </div>
      </div>

      <!-- Google Sheets sync now -->
      <div class="card">
        <div class="card-header"><span class="card-title">🔄 Συγχρονισμός από Google Sheets</span></div>
        <div style="padding:16px">
          <div style="font-size:13px;color:var(--text-2);margin-bottom:14px">Διαβάζει το Google Sheet που έχεις ρυθμίσει στις Συνδέσεις και εισάγει νέες εγγραφές στο Supabase.</div>
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <button class="btn btn-primary" id="sync-gdpr-now">🔄 Sync Ιατρικό Ιστορικό</button>
            <button class="btn btn-ghost" id="sync-consult-now">🔄 Sync Consultation</button>
          </div>
          <div id="sync-result" style="margin-top:12px;font-size:12px"></div>
        </div>
      </div>
    </div>`:''}

    <!-- USERS TAB -->
    ${settingsTab==='users'?`
    <div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <div><h2 style="font-size:16px;font-weight:600">Διαχείριση Χρηστών</h2>
          <p style="font-size:12px;color:var(--text-2);margin-top:3px">${isSuperAdmin()?'Όλες οι κλινικές':'Χρήστες κλινικής '+esc(S.clinic&&S.clinic.name||'')}</p>
        </div>
        <button class="btn btn-primary" data-modal="new-user">+ Νέος Χρήστης</button>
      </div>
      <div class="card">
        <div class="table-wrap"><table>
          <thead><tr><th>Χρήστης</th><th>Email</th><th>Ρόλος</th><th>Κλινική</th><th>Κατάσταση</th><th></th></tr></thead>
          <tbody id="users-tbody">
            <tr><td colspan="6" style="padding:20px;text-align:center;color:var(--text-2)">
              <button class="btn btn-ghost btn-sm" id="load-users-btn">🔄 Φόρτωση χρηστών</button>
            </td></tr>
          </tbody>
        </table></div>
      </div>
    </div>`:''}

    <!-- ACCOUNT TAB -->
    ${settingsTab==='account'?`
    <div class="card" style="max-width:400px">
      <div class="card-header"><span class="card-title">Πληροφορίες Λογαριασμού</span></div>
      <div style="padding:16px">
        ${[['Όνομα',(S.profile&&S.profile.full_name)],['Email',S.user&&S.user.email],['Ρόλος',ROLES[(S.profile&&S.profile.role)]||(S.profile&&S.profile.role)]].map(([k,v])=>`
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-2);font-size:13px">
          <span style="color:var(--text-2)">${k}</span><span style="font-weight:500">${esc(v||'—')}</span>
        </div>`).join('')}
        <button class="btn btn-danger" style="margin-top:16px;width:100%;justify-content:center" id="settings-logout">Αποσύνδεση</button>
      </div>
    </div>`:''}
  </div>`;
}

// ── MODALS ──
function renderModal() {
  const existing = document.getElementById('modal-overlay');
  if (existing) existing.remove();
  const div = document.createElement('div');
  div.id = 'modal-overlay';
  div.className = 'modal-overlay';
  const content = {
    'new-patient': modalNewPatient,
    'new-appt': modalNewAppt,
    'new-lead': modalNewLead,
    'new-clinic': modalNewClinic,
    'new-laser': modalNewLaser,
    'new-consent-tmpl': modalNewConsentTmpl,
    'new-user': modalNewUser,
  }[S.modal];
  if (!content) return;
  div.innerHTML = content();
  document.body.appendChild(div);
  div.onclick = e => { if(e.target===div) closeModal(); };
  bindModalEvents();
}

function closeModal() { S.modal=null; S.modalData={}; const _mo=document.getElementById('modal-overlay');if(_mo)_mo.remove(); }

