// ── BIND EVENTS ──
function bindEvents() {
  // Login
  const loginBtn = document.getElementById('login-btn');
  if (loginBtn) {
    const doLogin = async () => {
      const email = document.getElementById('login-email').value;
      const pass = document.getElementById('login-pass').value;
      loginBtn.textContent = 'Σύνδεση...'; loginBtn.disabled = true;
      try { await login(email, pass); }
      catch(e) {
        const err = document.getElementById('login-err');
        err.textContent = e.message||'Λάθος στοιχεία'; err.style.display='block';
        loginBtn.textContent = 'Σύνδεση →'; loginBtn.disabled = false;
      }
    };
    loginBtn.onclick = doLogin;
    const _lp=document.getElementById('login-pass');if(_lp)_lp.addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });
  }

  // Nav
  document.querySelectorAll('[data-page]').forEach(el => {
    el.onclick = () => { S.sidebarOpen=false; S.filter='all'; S.search=''; S.page=el.dataset.page; loadPageData(); render(); };
  });

  // Patients
  document.querySelectorAll('[data-patient]').forEach(el => {
    el.onclick = e => { if(!e.target.closest('button[data-patient]')&&!e.target.matches('button[data-patient]')) { loadPatientDetail(el.dataset.patient); } };
  });
  document.querySelectorAll('button[data-patient]').forEach(el => {
    el.onclick = e => { e.stopPropagation(); loadPatientDetail(el.dataset.patient); };
  });

  // Filter tabs
  document.querySelectorAll('[data-filter]').forEach(el => {
    el.onclick = () => { S.filter=el.dataset.filter; render(); };
  });

  // Search
  // (local search removed — using global search topbar)

  // Appointment status change
  document.querySelectorAll('[data-appt-status]').forEach(el => {
    el.onchange = async () => {
      await sb.from('appointments').update({status:el.value}).eq('id',el.dataset.apptStatus);
      loadPageData();
    };
  });

  // Modals trigger
  document.querySelectorAll('[data-modal]').forEach(el => {
    el.onclick = () => { S.modal=el.dataset.modal; render(); };
  });

  // Save laser form detail
  const _slf = document.getElementById('save-laser-form');
  if (_slf) _slf.addEventListener('click', async () => {
    if (!S.laserFormId) return;
    _slf.textContent='Αποθήκευση...'; _slf.disabled=true;
    const notes = document.getElementById('treatment-notes');
    const hairColor = document.getElementById('hair-color');
    const startDate = document.getElementById('start-date');
    const consentSigned = document.getElementById('consent-signed');
    const {error} = await sb.from('laser_forms').update({
      body_parts: _laserBodyParts,
      skin_type: S.laserFormDetail&&S.laserFormDetail.skin_type||'',
      treatment_notes: notes?notes.value:'',
      consent_signed: consentSigned?consentSigned.checked:false,
      machine_settings: {
        hair_color: hairColor?hairColor.value:'',
        start_date: startDate?startDate.value:'',
        regions: _laserRegions,
      }
    }).eq('id',S.laserFormId);
    if (error) { alert(error.message); _slf.textContent='💾 Αποθήκευση'; _slf.disabled=false; return; }
    _slf.textContent='✓ Αποθηκεύτηκε!';
    setTimeout(()=>{ _slf.textContent='💾 Αποθήκευση'; _slf.disabled=false; }, 2000);
  });

  // Patient detail tabs
  document.querySelectorAll('[data-pat-tab]').forEach(el => {
    el.onclick = () => { S.patTab=el.dataset.patTab; render(); };
  });

  // Sync patient from Google Sheet
  const _spsb = document.getElementById('sync-patient-sheet-btn');
  if (_spsb) _spsb.addEventListener('click', async () => {
    const p = S.patientDetail;
    if (!p) return;
    const integrations = (S.clinic&&S.clinic.integrations)||{};
    const sheetId = integrations.gdpr_sheet_id || '1enyraKQzFwRd8V8hTykTg-TCZuS0B2egrXo3MXh-aA8';
    _spsb.textContent='⏳ Φόρτωση...'; _spsb.disabled=true;
    try {
      const [rows1, rows2] = await Promise.all([
        fetchGoogleSheet(sheetId, 'Νέα Ιστορικά').catch(()=>[]),
        fetchGoogleSheet(sheetId, 'Παλιά Ιστορικά').catch(()=>[])
      ]);
      const allRows = [...rows1, ...rows2];
      const phone = normalizePhone(p.phone||'');
      const name = (p.full_name||'').toLowerCase().split(' ')[0];
      // Find matching row
      const match = allRows.find(row => {
        const rPhone = normalizePhone(row['Τηλέφωνο:']||row['Τηλέφωνο']||'');
        const rName = (row['Ονοματεπώνυμο:']||row['Ονοματεπώνυμο']||'').toLowerCase();
        return (phone&&rPhone===phone)||(name&&rName.includes(name));
      });
      if (!match) { _spsb.textContent='❌ Δεν βρέθηκε'; setTimeout(()=>{ _spsb.textContent='🔄 Sync από Sheet'; _spsb.disabled=false; },2000); return; }
      // Update patient with smart column matching
      const getCol = (row, keywords) => Object.keys(row).reduce((val, k) => {
        if (val) return val;
        if (keywords.some(kw => k.includes(kw))) return row[k]||'';
        return val;
      }, '')||'';
      const updates = {
        medical_history: getCol(match, ['ΙΑΤΡΙΚΟ ΙΣΤΟΡΙΚΟ','Ιατρικό Ιστορικό'])||p.medical_history,
        allergies: getCol(match, ['Αλλεργίες'])||p.allergies,
        medications: getCol(match, ['παθήσεις','φαρμακευτική'])||p.medications,
        previous_treatments: getCol(match, ['Προηγούμενες αισθητικές'])||p.previous_treatments,
        source: getCol(match, ['γνωρίσατε'])||p.source,
        gdpr_signed: true,
        city: getCol(match, ['Κατοικίας','Περιοχή'])||p.city,
        dob: parseGreekDate(getCol(match, ['Γέννησης']))||p.dob,
      };
      await sb.from('patients').update(updates).eq('id',p.id);
      Object.assign(S.patientDetail, updates);
      _spsb.textContent='✓ Ενημερώθηκε!';
      render();
      setTimeout(()=>{ _spsb.textContent='🔄 Sync από Sheet'; _spsb.disabled=false; },2000);
    } catch(e) {
      _spsb.textContent='❌ '+e.message.slice(0,30);
      setTimeout(()=>{ _spsb.textContent='🔄 Sync από Sheet'; _spsb.disabled=false; },3000);
    }
  });

  // Load consultations from Google Sheets
  const _lcb = document.getElementById('load-consultations-btn');
  if (_lcb) _lcb.addEventListener('click', async () => {
    const integrations = (S.clinic&&S.clinic.integrations)||{};
    const sheetId = integrations.consultation_sheet_id;
    const sheetTab = integrations.consultation_sheet_tab||'';
    if (!sheetId) { alert('Ρύθμισε πρώτα το Consultation Sheet στις Ρυθμίσεις → Συνδέσεις'); return; }
    _lcb.textContent='Φόρτωση...'; _lcb.disabled=true;
    try {
      const rows = await fetchGoogleSheet(sheetId, sheetTab);
      const phone = normalizePhone(S.patientDetail&&S.patientDetail.phone||'');
      const name = (S.patientDetail&&S.patientDetail.full_name||'').toLowerCase();
      S.patConsultations = rows.filter(r => {
        const rPhone = normalizePhone(r['Τηλέφωνο:']||r['Τηλέφωνο']||r['phone']||'');
        const rName = (r['Ονοματεπώνυμο:']||r['Ονοματεπώνυμο']||'').toLowerCase();
        return (phone&&rPhone===phone)||(name&&rName.includes(name.split(' ')[0]));
      });
      render();
    } catch(e) { alert(e.message); _lcb.textContent='🔄 Φόρτωση'; _lcb.disabled=false; }
  });

  // Also auto-load consultations when tab opens if sheet is configured
  if (S.patTab==='consultation' && !(S.patConsultations&&S.patConsultations.length)) {
    const integrations = (S.clinic&&S.clinic.integrations)||{};
    if (integrations.consultation_sheet_id && S.patientDetail) {
      fetchGoogleSheet(integrations.consultation_sheet_id, integrations.consultation_sheet_tab||'').then(rows => {
        const phone = normalizePhone(S.patientDetail.phone||'');
        const name = (S.patientDetail.full_name||'').toLowerCase();
        S.patConsultations = rows.filter(r => {
          const rPhone = normalizePhone(r['Τηλέφωνο:']||r['Τηλέφωνο']||r['phone']||'');
          const rName = (r['Ονοματεπώνυμο:']||r['Ονοματεπώνυμο']||'').toLowerCase();
          return (phone&&rPhone===phone)||(name&&rName.includes(name.split(' ')[0]));
        });
        render();
      }).catch(()=>{});
    }
  }

  // Calendar controls
  document.querySelectorAll('[data-cal-nav]').forEach(el => {
    el.onclick = () => {
      const d = S.calDate ? new Date(S.calDate) : new Date();
      const delta = parseInt(el.dataset.calNav);
      if (S.calView==='week') d.setDate(d.getDate() + delta*7);
      else d.setDate(d.getDate() + delta);
      S.calDate = d.toISOString();
      render();
    };
  });
  const _ct=document.querySelector('[data-cal-today]');if(_ct)_ct.addEventListener('click', () => {
    S.calDate = new Date().toISOString(); render();
  });
  document.querySelectorAll('[data-cal-view]').forEach(el => {
    el.onclick = () => { S.calView=el.dataset.calView; render(); };
  });
  document.querySelectorAll('[data-cal-mode]').forEach(el => {
    el.onclick = () => { S.calMode=el.dataset.calMode; render(); };
  });
  document.querySelectorAll('[data-cal-day]').forEach(el => {
    el.onclick = () => { S.calDate=el.dataset.calDay; S.calView='day'; render(); };
  });

  // Calendar appointment click — show detail panel
  document.querySelectorAll('[data-appt-cal]').forEach(el => {
    el.onclick = (e) => {
      e.stopPropagation();
      const id = el.dataset.apptCal;
      const a = (S.appointments||[]).find(x=>x.id===id||x.id==id);
      if (!a) return;
      const canFin = canSee(['super_admin','clinic_admin']);
      const c = apptColor ? apptColor(a) : {bg:'#eee',border:'#999',text:'#333'};
      const start = new Date(a.start_time);
      const end = new Date(start.getTime()+(a.duration_minutes||60)*60000);
      const panel = document.getElementById('appt-detail-panel');
      const content = document.getElementById('appt-detail-content');
      if (!panel||!content) return;
      content.innerHTML = `
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
          <div style="width:36px;height:36px;border-radius:50%;background:${c.bg};display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;color:${c.text}">${initials(a.patients&&a.patients.full_name)}</div>
          <div>
            <div style="font-size:14px;font-weight:500">${esc(a.patients&&a.patients.full_name||'—')}</div>
            <div style="font-size:12px;color:var(--text-2)">${esc(a.patients&&a.patients.phone||'')}</div>
          </div>
        </div>
        ${[
          ['Υπηρεσία', a.service_name],
          ['Ώρα', start.toLocaleTimeString('el-GR',{hour:'2-digit',minute:'2-digit'})+' – '+end.toLocaleTimeString('el-GR',{hour:'2-digit',minute:'2-digit'})],
          ['Διάρκεια', (a.duration_minutes||60)+' λεπτά'],
          ['Κατάσταση', (STATUS_APPT[a.status]||STATUS_APPT.pending).l],
          ['GDPR', a.patients&&a.patients.gdpr_signed ? '✅ Υπογεγραμμένο' : '❌ Χωρίς GDPR'],
          ...(canFin && a.price ? [['Τιμή', euro(a.price)]] : []),
          ...(a.notes ? [['Σημειώσεις', a.notes]] : []),
        ].map(([k,v])=>`<div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border-2);font-size:12px"><span style="color:var(--text-2)">${k}</span><span style="font-weight:500;text-align:right;max-width:180px">${esc(v||'—')}</span></div>`).join('')}
        <div style="display:flex;gap:8px;margin-top:14px">
          <button class="btn btn-primary btn-sm" style="flex:1;justify-content:center" data-patient="${a.patient_id}">Καρτέλα ασθενή</button>
          <select data-appt-status="${a.id}" style="flex:1;font-size:11px;padding:5px;border:1px solid var(--border);border-radius:6px;font-family:var(--font)">
            ${Object.entries(STATUS_APPT).map(([k,v])=>`<option value="${k}" ${a.status===k?'selected':''}>${v.l}</option>`).join('')}
          </select>
        </div>`;
      panel.style.display = 'block';
      // Rebind patient link
      const _cp=content.querySelector('[data-patient]');if(_cp)_cp.addEventListener('click', () => {
        panel.style.display='none';
        loadPatientDetail(a.patient_id);
      });
      const _cs=content.querySelector('[data-appt-status]');if(_cs)_cs.addEventListener('change', async (ev) => {
        await sb.from('appointments').update({status:ev.target.value}).eq('id',a.id);
        await loadPageData();
      });
    };
  });

  // Global search
  const _gs = document.getElementById('global-search');
  if (_gs) {
    _gs.oninput = e => {
      S.globalSearch = e.target.value;
      clearTimeout(_searchTimeout);
      if (e.target.value.length >= 2) {
        _searchTimeout = setTimeout(() => {
          globalSearch(e.target.value);
          // Also filter patients list if on patients page
          if (S.page==='patients') render();
        }, 300);
      } else {
        S.globalResults = [];
        if (S.page==='patients') render();
        else render();
      }
    };
    _gs.onkeydown = e => {
      if (e.key==='Escape') { S.globalSearch=''; S.globalResults=[]; render(); }
      // Enter on patients page → close dropdown, keep filter
      if (e.key==='Enter' && S.globalResults&&S.globalResults.length>0) {
        const first = S.globalResults[0];
        if (first.type==='patient') { S.globalResults=[]; loadPatientDetail(first.id); }
      }
    };
  }

  // Search results click
  document.querySelectorAll('[data-search-result]').forEach(el => {
    el.onclick = () => {
      const type = el.dataset.searchResult;
      const id = el.dataset.searchId;
      S.globalSearch=''; S.globalResults=[];
      if (type==='patient'||type==='laser') loadPatientDetail(id);
      else if (type==='appointment') { S.page='appointments'; loadPageData(); render(); }
    };
  });

  // Voice agent
  const _vab = document.getElementById('voice-agent-btn');
  if (_vab) _vab.addEventListener('click', () => {
    if (S.voiceActive) stopVoiceAgent(); else startVoiceAgent();
  });

  // Keyboard shortcuts: Ctrl+K = search, Ctrl+Space = voice
  if (!window._kbBound) {
    window._kbBound = true;
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey||e.metaKey) && e.key==='k') {
        e.preventDefault();
        const gs = document.getElementById('global-search');
        if (gs) gs.focus();
      }
      if ((e.ctrlKey||e.metaKey) && e.key===' ') {
        e.preventDefault();
        if (S.voiceActive) stopVoiceAgent(); else startVoiceAgent();
      }
    });
  }

  document.querySelectorAll('[data-sms-tab]').forEach(el => {
    el.onclick = () => { S.smsTab=el.dataset.smsTab; render(); };
  });

  // Consent tabs
  document.querySelectorAll('[data-con-tab]').forEach(el => {
    el.onclick = () => { S.conTab=el.dataset.conTab; loadPageData(); };
  });

  // Load users
  const _lub = document.getElementById('load-users-btn');
  if (_lub) _lub.addEventListener('click', async () => {
    _lub.textContent='Φόρτωση...'; _lub.disabled=true;
    const {data:users, error} = isSuperAdmin()
      ? await sb.from('profiles').select('*, clinics(name)').order('full_name')
      : await sb.from('profiles').select('*, clinics(name)').eq('clinic_id', clinicId()).order('full_name');
    const tbody = document.getElementById('users-tbody');
    if (!tbody) return;
    if (error||!users||!users.length) {
      tbody.innerHTML=`<tr><td colspan="6" style="padding:20px;text-align:center;color:var(--text-2)">Δεν βρέθηκαν χρήστες</td></tr>`;
      return;
    }
    tbody.innerHTML = users.map(u=>`<tr>
      <td><div style="display:flex;align-items:center;gap:8px">
        <div style="width:28px;height:28px;border-radius:50%;background:var(--blue-soft);color:var(--blue);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600">${initials(u.full_name)}</div>
        <span style="font-weight:500;font-size:13px">${esc(u.full_name||'—')}</span>
      </div></td>
      <td style="font-size:12px;color:var(--text-2)">${esc(u.email||'—')}</td>
      <td>${badge(ROLES[u.role]||u.role,'#eef0fe','#2B3BF0')}</td>
      <td style="font-size:12px;color:var(--text-2)">${esc(u.clinics&&u.clinics.name||'—')}</td>
      <td>${badge('Ενεργός','#E1F5EE','#0F6E56')}</td>
      <td><button class="btn btn-ghost btn-xs" data-edit-user="${u.id}">✏</button></td>
    </tr>`).join('');
    // Rebind edit buttons
    document.querySelectorAll('[data-edit-user]').forEach(el => {
      el.onclick = () => alert('Επεξεργασία χρήστη — σύντομα διαθέσιμο');
    });
  });

  // Save new user
  const _snu = document.getElementById('save-new-user');
  if (_snu) _snu.addEventListener('click', async () => {
    const name = document.getElementById('nu-name').value.trim();
    const email = document.getElementById('nu-email').value.trim();
    const pass = document.getElementById('nu-pass').value;
    const role = document.getElementById('nu-role').value;
    const clinicIdVal = document.getElementById('nu-clinic').value;
    if (!name||!email||!pass) return alert('Συμπλήρωσε όλα τα υποχρεωτικά πεδία');
    if (pass.length < 6) return alert('Ο κωδικός πρέπει να έχει τουλάχιστον 6 χαρακτήρες');
    _snu.textContent='Δημιουργία...'; _snu.disabled=true;
    // Create auth user via secure Edge Function. Δεν χρησιμοποιούμε ποτέ service key στο frontend.
    try {
      await createUserSecurely({
        name, email, password: pass, role, clinic_id: clinicIdVal || null
      });
      closeModal();
      _snu.textContent='✓ Δημιουργήθηκε!';
      setTimeout(()=>{ _snu.textContent='Δημιουργία Χρήστη'; _snu.disabled=false; }, 2000);
      // Reload users list
      setTimeout(()=>{
        const lb = document.getElementById('load-users-btn');
        if (lb) lb.click();
      }, 500);
    } catch(err) {
      alert('Σφάλμα: ' + err.message);
      _snu.textContent='Δημιουργία Χρήστη';
      _snu.disabled=false;
    }
  });

  // Booking247 sync
  const _sb247sync = document.getElementById('sync-booking247-now');
  if (_sb247sync) _sb247sync.addEventListener('click', () => syncBooking247(false));
  const _sb247prev = document.getElementById('sync-booking247-preview');
  if (_sb247prev) _sb247prev.addEventListener('click', () => syncBooking247(true));

  // Settings tabs
  document.querySelectorAll('[data-settings-tab]').forEach(el => {
    el.onclick = () => { S.settingsTab=el.dataset.settingsTab; render(); };
  });

  // Save clinic settings (hours/slot)
  const _scs = document.getElementById('save-clinic-settings');
  if (_scs) _scs.addEventListener('click', async () => {
    const start = document.getElementById('clinic-start');
    const end = document.getElementById('clinic-end');
    const slot = document.getElementById('clinic-slot');
    const settings = {
      start_hour: start ? parseInt(start.value) : 9,
      end_hour: end ? parseInt(end.value) : 20,
      slot_minutes: slot ? parseInt(slot.value) : 30,
    };
    const {error} = await sb.from('clinics').update({settings}).eq('id',clinicId());
    if (error) { alert(error.message); return; }
    if (S.clinic) S.clinic.settings = settings;
    _scs.textContent='✓ Αποθηκεύτηκε!';
    setTimeout(()=>{ _scs.textContent='Αποθήκευση'; }, 2000);
  });

  // Save GDPR Sheet
  const _sgdpr = document.getElementById('save-gdpr-sheet');
  if (_sgdpr) _sgdpr.addEventListener('click', async () => {
    const id = extractSheetId(document.getElementById('gdpr-sheet-id').value);
    const tab = document.getElementById('gdpr-sheet-tab').value;
    const c = S.clinic;
    const integrations = Object.assign({}, (c&&c.integrations)||{}, {gdpr_sheet_id:id, gdpr_sheet_tab:tab});
    const {error} = await sb.from('clinics').update({integrations}).eq('id',clinicId());
    if (error) { alert(error.message); return; }
    if (S.clinic) S.clinic.integrations = integrations;
    _sgdpr.textContent='✓ Αποθηκεύτηκε!';
    setTimeout(()=>{ _sgdpr.textContent='Αποθήκευση'; loadPageData(); }, 1500);
  });

  // Test GDPR Sheet
  const _tgdpr = document.getElementById('test-gdpr-sheet');
  if (_tgdpr) _tgdpr.addEventListener('click', async () => {
    const id = extractSheetId(document.getElementById('gdpr-sheet-id').value);
    const tab = document.getElementById('gdpr-sheet-tab').value;
    const result = document.getElementById('gdpr-sheet-result');
    if (!id) { result.innerHTML='<span style="color:var(--red)">Βάλε πρώτα Sheet ID</span>'; return; }
    result.innerHTML='<span style="color:var(--text-2)">Ελέγχω σύνδεση...</span>';
    try {
      const rows = await fetchGoogleSheet(id, tab);
      result.innerHTML=`<span style="color:var(--green)">✓ Βρέθηκαν ${rows.length} εγγραφές</span>`;
    } catch(e) { result.innerHTML=`<span style="color:var(--red)">✗ ${e.message}</span>`; }
  });

  // Save Consultation Sheet
  const _sconsult = document.getElementById('save-consult-sheet');
  if (_sconsult) _sconsult.addEventListener('click', async () => {
    const id = extractSheetId(document.getElementById('consult-sheet-id').value);
    const tab = document.getElementById('consult-sheet-tab').value;
    const integrations = Object.assign({}, (S.clinic&&S.clinic.integrations)||{}, {consultation_sheet_id:id, consultation_sheet_tab:tab});
    const {error} = await sb.from('clinics').update({integrations}).eq('id',clinicId());
    if (error) { alert(error.message); return; }
    if (S.clinic) S.clinic.integrations = integrations;
    _sconsult.textContent='✓ Αποθηκεύτηκε!';
    setTimeout(()=>{ _sconsult.textContent='Αποθήκευση'; loadPageData(); }, 1500);
  });

  // Test Consultation Sheet
  const _tconsult = document.getElementById('test-consult-sheet');
  if (_tconsult) _tconsult.addEventListener('click', async () => {
    const id = extractSheetId(document.getElementById('consult-sheet-id').value);
    const tab = document.getElementById('consult-sheet-tab').value;
    const result = document.getElementById('consult-sheet-result');
    if (!id) { result.innerHTML='<span style="color:var(--red)">Βάλε πρώτα Sheet ID</span>'; return; }
    result.innerHTML='<span style="color:var(--text-2)">Ελέγχω σύνδεση...</span>';
    try {
      const rows = await fetchGoogleSheet(id, tab);
      result.innerHTML=`<span style="color:var(--green)">✓ Βρέθηκαν ${rows.length} εγγραφές</span>`;
    } catch(e) { result.innerHTML=`<span style="color:var(--red)">✗ ${e.message}</span>`; }
  });

  // Save Booking247
  const _sb247 = document.getElementById('save-booking247');
  if (_sb247) _sb247.addEventListener('click', async () => {
    const key = document.getElementById('booking247-key').value;
    const company = document.getElementById('booking247-company').value;
    const integrations = Object.assign({}, (S.clinic&&S.clinic.integrations)||{}, {booking247_key:key, booking247_company:company});
    const {error} = await sb.from('clinics').update({integrations}).eq('id',clinicId());
    if (error) { alert(error.message); return; }
    if (S.clinic) S.clinic.integrations = integrations;
    _sb247.textContent='✓ Αποθηκεύτηκε!';
    setTimeout(()=>{ _sb247.textContent='Αποθήκευση'; }, 2000);
  });

  // CSV Patients upload
  const _cpf = document.getElementById('csv-patients-file');
  if (_cpf) _cpf.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      const rows = parseCSV(ev.target.result);
      S._csvPatients = rows;
      showCSVPreview('csv-patients-preview', rows, 5);
      document.getElementById('import-patients-btn').style.display='inline-flex';
      document.getElementById('clear-patients-csv').style.display='inline-flex';
    };
    reader.readAsText(file, 'UTF-8');
  });

  const _ipb = document.getElementById('import-patients-btn');
  if (_ipb) _ipb.addEventListener('click', async () => {
    if (!S._csvPatients||!S._csvPatients.length) return;
    const result = document.getElementById('import-patients-result');
    result.innerHTML='<span style="color:var(--text-2)">Εισαγωγή...</span>';
    _ipb.disabled=true;
    let ok=0, skip=0, err=0;
    for (const row of S._csvPatients) {
      const phone = normalizePhone(row['Τηλέφωνο']||row['phone']||row['Phone']||row['τηλέφωνο']||'');
      const name = row['Ονοματεπώνυμο']||row['name']||row['Όνομα']||row['full_name']||'';
      if (!name&&!phone) { skip++; continue; }
      const payload = {
        clinic_id: clinicId(),
        full_name: name.trim(),
        phone: phone,
        email: row['Email']||row['email']||'',
        dob: parseGreekDate(row['Ημερομηνία Γέννησης']||row['Ημ.Γέννησης']||''),
        city: row['Περιοχή Κατοικίας']||row['Περιοχή']||row['city']||'',
        source: 'import',
        status: 'active',
      };
      const {error} = await sb.from('patients').upsert(payload, {onConflict:'clinic_id,phone',ignoreDuplicates:true});
      if (error) err++; else ok++;
    }
    result.innerHTML=`<span style="color:var(--green)">✓ Εισήχθησαν: ${ok}</span> · <span style="color:var(--text-2)">Παραλείφθηκαν: ${skip}</span>${err?` · <span style="color:var(--red)">Σφάλματα: ${err}</span>`:''}`;
    _ipb.disabled=false;
    await loadPageData();
  });

  // CSV Appointments upload
  const _caf = document.getElementById('csv-appts-file');
  if (_caf) _caf.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      const rows = parseCSV(ev.target.result);
      S._csvAppts = rows;
      showCSVPreview('csv-appts-preview', rows, 5);
      document.getElementById('import-appts-btn').style.display='inline-flex';
      document.getElementById('clear-appts-csv').style.display='inline-flex';
    };
    reader.readAsText(file, 'UTF-8');
  });

  const _iab = document.getElementById('import-appts-btn');
  if (_iab) _iab.addEventListener('click', async () => {
    if (!S._csvAppts||!S._csvAppts.length) return;
    const result = document.getElementById('import-appts-result');
    result.innerHTML='<span style="color:var(--text-2)">Εισαγωγή ραντεβού...</span>';
    _iab.disabled=true;
    let ok=0, skip=0, err=0;
    for (const row of S._csvAppts) {
      const phone = normalizePhone(row['Τηλέφωνο']||row['phone']||'');
      const dateStr = row['Ημερομηνία']||row['date']||row['Date']||'';
      const timeStr = row['Ώρα']||row['time']||row['Time']||'';
      if (!dateStr) { skip++; continue; }
      // Find patient by phone
      let patientId = null;
      if (phone) {
        const {data:pt} = await sb.from('patients').select('id').eq('clinic_id',clinicId()).eq('phone',phone).single();
        if (pt) patientId = pt.id;
      }
      const startTime = parseDateTime(dateStr, timeStr);
      if (!startTime) { skip++; continue; }
      const payload = {
        clinic_id: clinicId(),
        patient_id: patientId,
        service_name: row['Υπηρεσία']||row['service']||row['Service']||'',
        start_time: startTime,
        duration_minutes: parseInt(row['Διάρκεια']||row['duration']||'60')||60,
        price: parseFloat(row['Τιμή']||row['price']||'')||null,
        status: mapApptStatus(row['Κατάσταση']||row['status']||'confirmed'),
        notes: row['Σημειώσεις']||row['notes']||'',
      };
      const {error} = await sb.from('appointments').insert(payload);
      if (error) err++; else ok++;
    }
    result.innerHTML=`<span style="color:var(--green)">✓ Εισήχθησαν: ${ok}</span> · <span style="color:var(--text-2)">Παραλείφθηκαν: ${skip}</span>${err?` · <span style="color:var(--red)">Σφάλματα: ${err}</span>`:''}`;
    _iab.disabled=false;
    await loadPageData();
  });

  // Sync GDPR Sheet now - reads BOTH tabs
  const _sgn = document.getElementById('sync-gdpr-now');
  if (_sgn) _sgn.addEventListener('click', async () => {
    const integrations = (S.clinic&&S.clinic.integrations)||{};
    const sheetId = integrations.gdpr_sheet_id || '1enyraKQzFwRd8V8hTykTg-TCZuS0B2egrXo3MXh-aA8';
    const result = document.getElementById('sync-result');
    if (!sheetId) { result.innerHTML='<span style="color:var(--red)">Δεν έχεις ρυθμίσει Google Sheet.</span>'; return; }
    result.innerHTML='<span style="color:var(--text-2)">Φόρτωση από Google Sheets (Νέα + Παλιά Ιστορικά)...</span>';
    _sgn.disabled=true;
    try {
      // Read both tabs
      const [rows1, rows2] = await Promise.all([
        fetchGoogleSheet(sheetId, 'Νέα Ιστορικά').catch(()=>[]),
        fetchGoogleSheet(sheetId, 'Παλιά Ιστορικά').catch(()=>[])
      ]);
      const allRows = [...rows1, ...rows2];
      let ok=0, skip=0, updated=0;

      for (const row of allRows) {
        // Map columns from the sheet
        const phone = normalizePhone(
          row['Τηλέφωνο:']||row['Τηλέφωνο']||row['phone']||''
        );
        const name = (
          row['Ονοματεπώνυμο:']||row['Ονοματεπώνυμο']||row['name']||''
        ).trim();
        const email = row['Email:']||row['Email']||'';
        const dob = parseGreekDate(row['Ημερομηνία Γέννησης']||row['Ημ. Γέννησης']||'');
        const city = row['Περιοχή Κατοικίας:']||row['Περιοχή Κατοικίας']||row['Περιοχή']||'';
        const source = row['Από πού μας γνωρίσατε:']||row['Από πού μας γνωρίσατε']||'';
        // Find medical history - column has emoji prefix 🩺
        const medHistory = Object.keys(row).reduce((val, k) => {
          if (val) return val;
          if (k.includes('ΙΑΤΡΙΚΟ ΙΣΤΟΡΙΚΟ')||k.includes('Ιατρικό Ιστορικό')) return row[k]||'';
          return val;
        }, '')||'';
        // Find allergies
        const allergies = Object.keys(row).reduce((val, k) => {
          if (val) return val;
          if (k.includes('Αλλεργίες')) return row[k]||'';
          return val;
        }, '')||'';
        // Other conditions / medications
        const otherConditions = Object.keys(row).reduce((val, k) => {
          if (val) return val;
          if (k.includes('παθήσεις')||k.includes('φαρμακευτική αγωγή')) return row[k]||'';
          return val;
        }, '')||'';
        // Previous treatments
        const prevTreatments = Object.keys(row).reduce((val, k) => {
          if (val) return val;
          if (k.includes('Προηγούμενες αισθητικές')||k.includes('προηγούμενες')) return row[k]||'';
          return val;
        }, '')||'';
        // Avoid areas
        const avoidAreas = Object.keys(row).reduce((val, k) => {
          if (val) return val;
          if (k.includes('αποφυγή')) return row[k]||'';
          return val;
        }, '')||'';
        // GDPR - find column with "Συναινώ" or "Συμφωνώ"
        const gdprValue = Object.keys(row).reduce((val, k) => {
          if (val) return val;
          if (k.includes('Συναιν')||k.includes('Συμφων')||k.includes('GDPR')) return row[k]||'';
          return val;
        }, '')||'Ναί';
        const gdprSigned = gdprValue.toLowerCase().includes('ναι')||gdprValue.toLowerCase().includes('ναί');
        const marketing = Object.keys(row).reduce((val, k) => {
          if (val) return val;
          if (k.includes('email')||k.includes('προσφορές')) return row[k]||'';
          return val;
        }, '')||'';
        const timestamp = row['Στήλη 1']||row['Timestamp']||'';

        if (!name&&!phone) { skip++; continue; }

        // Build upsert payload
        const payload = {
          clinic_id: clinicId(),
          full_name: name||undefined,
          phone: phone||undefined,
          email: email||undefined,
          dob: dob||undefined,
          city: city||undefined,
          source: source||undefined,
          medical_history: medHistory||undefined,
          allergies: allergies||undefined,
          medications: otherConditions||undefined,
          previous_treatments: prevTreatments||undefined,
          gdpr_signed: gdprSigned,
          status: 'active',
        };

        // Remove undefined keys
        Object.keys(payload).forEach(k => payload[k]===undefined && delete payload[k]);

        // Find existing patient by phone or name
        let existingId = null;
        if (phone) {
          const {data:byPhone} = await sb.from('patients').select('id').eq('clinic_id',clinicId()).eq('phone',phone).limit(1);
          if (byPhone&&byPhone.length) existingId = byPhone[0].id;
        }
        if (!existingId && name) {
          const firstName = name.split(' ')[0];
          const {data:byName} = await sb.from('patients').select('id').eq('clinic_id',clinicId()).ilike('full_name','%'+firstName+'%').limit(1);
          if (byName&&byName.length) existingId = byName[0].id;
        }

        if (existingId) {
          // Update existing patient with medical history
          const {error} = await sb.from('patients').update(payload).eq('id',existingId);
          if (error) { console.error(error); skip++; } else { updated++; ok++; }
        } else {
          // Create new patient
          const {error} = await sb.from('patients').insert(payload);
          if (error) { console.error(error); skip++; } else ok++;
        }
      }
      result.innerHTML=`<span style="color:var(--green)">✓ Sync ολοκληρώθηκε!</span> ${ok} εγγραφές · ${updated} ενημερώθηκαν · ${skip} παραλείφθηκαν`;
      if(result) result.innerHTML += `<br><span style="color:var(--text-2);font-size:11px">Νέα Ιστορικά: ${rows1.length} · Παλιά Ιστορικά: ${rows2.length}</span>`;
      await loadPageData();
    } catch(e) {
      result.innerHTML=`<span style="color:var(--red)">✗ ${e.message}</span>`;
    }
    _sgn.disabled=false;
  });

  // Clear CSV buttons
  const _ccpb = document.getElementById('clear-patients-csv');
  if (_ccpb) _ccpb.addEventListener('click', () => {
    S._csvPatients=null;
    document.getElementById('csv-patients-preview').innerHTML='';
    document.getElementById('import-patients-btn').style.display='none';
    _ccpb.style.display='none';
    document.getElementById('csv-patients-file').value='';
  });
  const _ccab = document.getElementById('clear-appts-csv');
  if (_ccab) _ccab.addEventListener('click', () => {
    S._csvAppts=null;
    document.getElementById('csv-appts-preview').innerHTML='';
    document.getElementById('import-appts-btn').style.display='none';
    _ccab.style.display='none';
    document.getElementById('csv-appts-file').value='';
  });

  // Settings logout
  const _sl=document.getElementById('settings-logout');if(_sl)_sl.addEventListener('click', async () => { await logout(); });

  // Delete consent template
  document.querySelectorAll('[data-del-tmpl]').forEach(el => {
    el.onclick = async () => {
      if (!confirm('Διαγραφή template;')) return;
      await sb.from('service_consent_templates').delete().eq('id',el.dataset.delTmpl);
      loadPageData();
    };
  });

  // Laser form click
  document.querySelectorAll('[data-laser]').forEach(el => {
    el.onclick = () => { loadLaserForm(el.dataset.laser); };
  });
  const _hb=document.getElementById('hamburger');if(_hb)_hb.addEventListener('click', () => { S.sidebarOpen=!S.sidebarOpen; render(); });
  const _ov=document.getElementById('overlay');if(_ov)_ov.addEventListener('click', () => { S.sidebarOpen=false; render(); });
  const _cb=document.getElementById('collapse-btn');if(_cb)_cb.addEventListener('click', () => { S.sidebarCollapsed=!S.sidebarCollapsed; render(); });
  const _lb=document.getElementById('logout-btn');if(_lb)_lb.addEventListener('click', async () => { await logout(); });

  // Clinic picker
  const _cpb=document.getElementById('clinic-picker-btn');if(_cpb)_cpb.addEventListener('click', () => {
    const dd = document.getElementById('clinic-dropdown');
    if (dd) dd.style.display = dd.style.display==='none' ? 'block' : 'none';
  });
  document.querySelectorAll('[data-clinic]').forEach(el => {
    el.onclick = () => { selectClinic(el.dataset.clinic); };
  });
}

function bindModalEvents() {
  // Save patient
  const _sp=document.getElementById('save-patient');if(_sp)_sp.addEventListener('click', async () => {
    const name = document.getElementById('f-name').value.trim();
    const phone = document.getElementById('f-phone').value.trim();
    if (!name||!phone) return alert('Συμπλήρωσε υποχρεωτικά πεδία');
    const btn = document.getElementById('save-patient');
    btn.textContent='Αποθήκευση...'; btn.disabled=true;
    const {error} = await sb.from('patients').insert({
      full_name:name, phone, email:document.getElementById('f-email').value,
      gender:document.getElementById('f-gender').value,
      status:document.getElementById('f-status').value,
      source:document.getElementById('f-source').value,
      clinic_id:clinicId()
    });
    if (error) { alert(error.message); btn.textContent='Αποθήκευση'; btn.disabled=false; return; }
    closeModal(); await loadPageData();
  });

  // Patient search for appointment
  const ps = document.getElementById('a-patient-search');
  if (ps) {
    ps.oninput = async () => {
      const q = ps.value.trim();
      const res = document.getElementById('a-patient-results');
      if (q.length < 2) { res.style.display='none'; return; }
      const {data} = await sb.from('patients').select('id,full_name,phone').eq('clinic_id',clinicId()).or(`full_name.ilike.%${q}%,phone.ilike.%${q}%`).limit(5);
      if (!data||!data.length) { res.style.display='none'; return; }
      res.innerHTML = data.map(p=>`<div style="padding:9px 12px;cursor:pointer;font-size:12px" data-pid="${p.id}" data-pname="${esc(p.full_name)}">${esc(p.full_name)} · ${esc(p.phone||'')}</div>`).join('');
      res.style.display='block';
      res.querySelectorAll('[data-pid]').forEach(el => {
        el.onclick = () => { document.getElementById('a-patient-id').value=el.dataset.pid; ps.value=el.dataset.pname; res.style.display='none'; };
        el.onmouseover = () => el.style.background='var(--surface)';
        el.onmouseout = () => el.style.background='';
      });
    };
  }

  // Save appointment
  const _sa=document.getElementById('save-appt');if(_sa)_sa.addEventListener('click', async () => {
    const pid = document.getElementById('a-patient-id').value;
    const time = document.getElementById('a-time').value;
    if (!time) return alert('Συμπλήρωσε ημερομηνία και ώρα');
    const btn = document.getElementById('save-appt');
    btn.textContent='Αποθήκευση...'; btn.disabled=true;
    const {error} = await sb.from('appointments').insert({
      clinic_id:clinicId(), patient_id:pid||null,
      service_name:document.getElementById('a-service').value,
      start_time:time,
      duration_minutes:parseInt(document.getElementById('a-duration').value)||60,
      price:parseFloat(document.getElementById('a-price').value)||null,
      notes:document.getElementById('a-notes').value,
      status:'pending'
    });
    if (error) { alert(error.message); btn.textContent='Αποθήκευση'; btn.disabled=false; return; }
    closeModal(); await loadPageData();
  });

  // Save lead
  const _sl2=document.getElementById('save-lead');if(_sl2)_sl2.addEventListener('click', async () => {
    const name = document.getElementById('l-name').value.trim();
    if (!name) return alert('Συμπλήρωσε όνομα');
    const btn = document.getElementById('save-lead');
    btn.textContent='Αποθήκευση...'; btn.disabled=true;
    const {error} = await sb.from('pipeline_leads').insert({
      clinic_id:clinicId(), name,
      phone:document.getElementById('l-phone').value,
      service:document.getElementById('l-service').value,
      estimated_value:parseFloat(document.getElementById('l-value').value)||null,
      stage:document.getElementById('l-stage').value
    });
    if (error) { alert(error.message); btn.textContent='Αποθήκευση'; btn.disabled=false; return; }
    closeModal(); await loadPageData();
  });

  // Save laser form
  const _slr=document.getElementById('save-laser');if(_slr)_slr.addEventListener('click', async () => {
    const pid = document.getElementById('lf-patient').value;
    if (!pid) return alert('Επίλεξε ασθενή');
    const btn = document.getElementById('save-laser');
    btn.textContent='Αποθήκευση...'; btn.disabled=true;
    const parts = document.getElementById('lf-parts').value.split(',').map(s=>s.trim()).filter(Boolean);
    const {error} = await sb.from('laser_forms').insert({
      clinic_id:clinicId(), patient_id:pid,
      gender:document.getElementById('lf-gender').value,
      session_number:parseInt(document.getElementById('lf-session').value)||1,
      body_parts:parts,
      notes:document.getElementById('lf-notes').value,
    });
    if (error) { alert(error.message); btn.textContent='Αποθήκευση'; btn.disabled=false; return; }
    closeModal(); await loadPageData();
  });

  // Save consent template
  const _sct=document.getElementById('save-consent-tmpl');if(_sct)_sct.addEventListener('click', async () => {
    const service = document.getElementById('ct-service').value.trim();
    const text = document.getElementById('ct-text').value.trim();
    if (!service||!text) return alert('Συμπλήρωσε όλα τα πεδία');
    const btn = document.getElementById('save-consent-tmpl');
    btn.textContent='Αποθήκευση...'; btn.disabled=true;
    const {error} = await sb.from('service_consent_templates').insert({
      clinic_id:clinicId(), service_name:service, consent_text:text
    });
    if (error) { alert(error.message); btn.textContent='Αποθήκευση'; btn.disabled=false; return; }
    closeModal(); await loadPageData();
  });
  const _sc2=document.getElementById('save-clinic');if(_sc2)_sc2.addEventListener('click', async () => {
    const name = document.getElementById('c-name').value.trim();
    if (!name) return alert('Συμπλήρωσε όνομα κλινικής');
    const btn = document.getElementById('save-clinic');
    btn.textContent='Αποθήκευση...'; btn.disabled=true;
    const {error} = await sb.from('clinics').insert({
      name, email:document.getElementById('c-email').value,
      phone:document.getElementById('c-phone').value,
      city:document.getElementById('c-city').value,
      address:document.getElementById('c-address').value,
      active:true
    });
    if (error) { alert(error.message); btn.textContent='Αποθήκευση'; btn.disabled=false; return; }
    closeModal(); await loadPageData();
  });
}


// ── TOOLTIP HELPERS ──
function showCalTooltip(el, e) {
  el.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';
  el.style.zIndex = 20;
  var tt = document.getElementById('cal-tooltip');
  if (!tt) return;
  var name = el.getAttribute('data-name')||'—';
  var svc = el.getAttribute('data-service')||'';
  var time = el.getAttribute('data-time')||'';
  var gdpr = el.getAttribute('data-gdpr')==='1';
  var vip = el.getAttribute('data-vip')==='1';
  var price = el.getAttribute('data-price')||'';
  tt.innerHTML = '<div style="font-weight:500;margin-bottom:4px">'+name+'</div>'
    +(svc?'<div>'+svc+'</div>':'')
    +'<div style="font-family:monospace;font-size:11px">'+time+'</div>'
    +(!gdpr?'<div style="color:#fca5a5;margin-top:4px">⚠ Χωρίς GDPR</div>':'')
    +(vip?'<div style="color:#c4b5fd;margin-top:4px">★ VIP</div>':'')
    +(price?'<div style="color:#6ee7b7;margin-top:4px;font-weight:500">'+price+'</div>':'');
  tt.style.display = 'block';
  tt.style.left = Math.min(e.clientX+12, window.innerWidth-260)+'px';
  tt.style.top = Math.min(e.clientY+12, window.innerHeight-160)+'px';
}
function hideCalTooltip(el) {
  el.style.boxShadow = 'none';
  el.style.zIndex = 5;
  var tt = document.getElementById('cal-tooltip');
  if (tt) tt.style.display = 'none';
}

function copyToClipboard(text, msgId) {
  navigator.clipboard.writeText(text).then(() => {
    const el = document.getElementById(msgId);
    if (el) { el.style.display='block'; setTimeout(()=>{ el.style.display='none'; }, 2000); }
  }).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta);
    const el = document.getElementById(msgId);
    if (el) { el.style.display='block'; setTimeout(()=>{ el.style.display='none'; }, 2000); }
  });
}

function toggleQR(elId, url) {
  const el = document.getElementById(elId);
  if (!el) return;
  if (el.style.display==='none'||!el.style.display) {
    el.style.display='block';
    if (!el.innerHTML) el.innerHTML=`<img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(url)}" alt="QR" style="border-radius:8px;border:1px solid var(--border-2)"/>`;
  } else { el.style.display='none'; }
}

function openSmsModal(link, formName) {
  const modal = document.getElementById('sms-link-modal');
  const title = document.getElementById('sms-modal-title');
  const text = document.getElementById('sms-link-text');
  if (!modal) return;
  if (title) title.textContent='Αποστολή SMS — '+formName;
  if (text) text.value='Παρακαλούμε συμπληρώστε τη φόρμα '+formName+': '+link;
  modal.style.display='flex';
}

// ── BOOKING247 EMAIL SYNC ──
function parseBooking247Email(snippet) {
  // Parse: Πελάτης: NAME Ημερομηνία: DD/MM/YYYY Ώρα: HH:MM Υπηρεσία: SERVICE Προσωπικό: STAFF
  const clean = snippet.replace(/&amp;/g,'&').replace(/<[^>]+>/g,'');
  const name = (clean.match(/Πελάτης:\s*([^\n]+?)(?:\s+Ημερομηνία|\s+Ώρα|$)/i)||[])[1]||'';
  const date = (clean.match(/Ημερομηνία:\s*(\d{2}\/\d{2}\/\d{4})/i)||[])[1]||'';
  const time = (clean.match(/Ώρα:\s*(\d{1,2}:\d{2})/i)||[])[1]||'09:00';
  const service = (clean.match(/Υπηρεσία:\s*([^\n]+?)(?:\s+Προσωπικό|$)/i)||[])[1]||'';
  const staff = (clean.match(/Προσωπικό:\s*([^\n]+?)(?:\s*$)/i)||[])[1]||'';
  if (!name||!date) return null;
  // Convert DD/MM/YYYY to ISO
  const [d,m,y] = date.split('/');
  const [h,min] = time.split(':');
  const startTime = `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}T${(h||'09').padStart(2,'0')}:${(min||'00').padStart(2,'0')}:00`;
  return { name: name.trim(), date, time, service: service.trim(), staff: staff.trim(), startTime };
}

async function syncBooking247(preview=false) {
  const resultEl = document.getElementById('booking247-sync-result');
  const previewEl = document.getElementById('booking247-preview-list');
  if (resultEl) resultEl.innerHTML='<span style="color:var(--text-2)">Φόρτωση emails...</span>';
  if (previewEl) previewEl.innerHTML='';

  // Fetch emails via Claude API (using the Anthropic API in artifact mode)
  // We parse the snippets we already have in state, OR fetch fresh via a backend
  // Since we're in browser, we use the gmail data we fetched earlier
  // For now, show the data we have and let user trigger sync

  try {
    // Call our backend sync endpoint (we'll use a simple fetch to Supabase edge function)
    // For now, parse from state or prompt user
    const cid = clinicId();
    if (!cid) { if(resultEl) resultEl.innerHTML='<span style="color:var(--red)">Επίλεξε κλινική πρώτα</span>'; return; }

    // Use the emails data from state if available
    const emails = S.booking247Emails||[];
    if (!emails.length) {
      if(resultEl) resultEl.innerHTML='<span style="color:var(--amber-dark)">⚠ Δεν υπάρχουν emails για sync. Χρησιμοποίησε το κουμπί "Sync από Claude" στη συνέχεια.</span>';
      return;
    }

    let ok=0, skip=0, err=0;
    const parsed = emails.map(e=>parseBooking247Email(e.snippet)).filter(Boolean);

    if (preview) {
      if(previewEl) previewEl.innerHTML=`
        <div style="margin-top:10px">
          <div style="font-size:11px;font-weight:600;color:var(--text-2);text-transform:uppercase;margin-bottom:8px">${parsed.length} ραντεβού βρέθηκαν:</div>
          <div style="max-height:300px;overflow-y:auto;border:1px solid var(--border-2);border-radius:8px">
            ${parsed.map(p=>`<div style="padding:10px 14px;border-bottom:1px solid var(--border-2);font-size:12px">
              <div style="font-weight:500">${esc(p.name)}</div>
              <div style="color:var(--text-2)">${esc(p.service)} · ${esc(p.date)} ${esc(p.time)}${p.staff?' · '+esc(p.staff):''}</div>
            </div>`).join('')}
          </div>
          <button class="btn btn-primary btn-sm" style="margin-top:10px" id="confirm-sync-btn">✓ Εισαγωγή όλων στο CRM</button>
        </div>`;
      // Bind confirm
      setTimeout(()=>{
        const cb = document.getElementById('confirm-sync-btn');
        if (cb) cb.addEventListener('click', ()=>syncBooking247(false));
      }, 100);
      return;
    }

    // Insert into Supabase
    for (const p of parsed) {
      // Find or create patient
      let patientId = null;
      const nameParts = p.name.trim().split(/\s+/);
      const {data:existing} = await sb.from('patients').select('id')
        .eq('clinic_id',cid)
        .ilike('full_name', '%'+nameParts[0]+'%')
        .limit(1);
      if (existing&&existing.length) {
        patientId = existing[0].id;
      } else {
        const {data:newPt} = await sb.from('patients').insert({
          clinic_id:cid, full_name:p.name, status:'active', source:'booking247'
        }).select('id').single();
        if (newPt) patientId = newPt.id;
      }
      // Insert appointment (avoid duplicates)
      const {data:existAppt} = await sb.from('appointments').select('id')
        .eq('clinic_id',cid)
        .eq('start_time',p.startTime)
        .eq('patient_id',patientId)
        .limit(1);
      if (existAppt&&existAppt.length) { skip++; continue; }
      const {error} = await sb.from('appointments').insert({
        clinic_id:cid, patient_id:patientId,
        service_name:p.service,
        start_time:p.startTime,
        status:'confirmed',
        notes:p.staff?'Προσωπικό: '+p.staff:'',
      });
      if (error) err++; else ok++;
    }
    if(resultEl) resultEl.innerHTML=`<span style="color:var(--green)">✓ Εισήχθησαν: ${ok}</span> · <span style="color:var(--text-2)">Ήδη υπάρχουν: ${skip}</span>${err?` · <span style="color:var(--red)">Σφάλματα: ${err}</span>`:''}`;
    await loadPageData();
  } catch(e) {
    if(resultEl) resultEl.innerHTML=`<span style="color:var(--red)">✗ ${e.message}</span>`;
  }
}

// ── GOOGLE SHEETS & CSV HELPERS ──
function extractSheetId(urlOrId) {
  if (!urlOrId) return '';
  const m = urlOrId.match(/\/spreadsheets\/d\/([a-zA-Z0-9_-]+)/);
  return m ? m[1] : urlOrId.trim();
}

async function fetchGoogleSheet(sheetId, tabName) {
  const gid = tabName ? `&sheet=${encodeURIComponent(tabName)}` : '';
  const url = `https://docs.google.com/spreadsheets/d/${sheetId}/gviz/tq?tqx=out:csv${gid}`;
  const resp = await fetch(url);
  if (!resp.ok) throw new Error('Δεν ήταν δυνατή η σύνδεση. Βεβαιώσου ότι το Sheet είναι δημόσιο.');
  const text = await resp.text();
  return parseCSV(text);
}

function parseCSV(text) {
  const lines = text.split('\n').filter(l => l.trim());
  if (!lines.length) return [];
  const headers = parseCSVLine(lines[0]).map(h => h.trim());
  const rows = [];
  for (let i=1; i<lines.length; i++) {
    const vals = parseCSVLine(lines[i]);
    const row = {};
    headers.forEach((h,j) => { row[h] = (vals[j]||'').trim(); });
    rows.push(row);
  }
  return rows;
}

function parseCSVLine(line) {
  const result = [];
  let current = '';
  let inQuotes = false;
  for (let i=0; i<line.length; i++) {
    const ch = line[i];
    if (ch==='"') {
      if (inQuotes && line[i+1]==='"') { current+='"'; i++; }
      else inQuotes = !inQuotes;
    } else if (ch===',' && !inQuotes) {
      result.push(current); current='';
    } else {
      current += ch;
    }
  }
  result.push(current);
  return result;
}

function showCSVPreview(containerId, rows, maxRows) {
  const el = document.getElementById(containerId);
  if (!el||!rows.length) return;
  const headers = Object.keys(rows[0]).slice(0,6);
  const preview = rows.slice(0, maxRows);
  el.innerHTML = `
    <div style="font-size:11px;color:var(--text-2);margin-bottom:6px">Προεπισκόπηση (${rows.length} εγγραφές συνολικά):</div>
    <div style="overflow-x:auto;border:1px solid var(--border-2);border-radius:8px">
      <table style="width:100%;border-collapse:collapse;font-size:11px">
        <thead><tr style="background:var(--surface)">${headers.map(h=>`<th style="padding:6px 8px;text-align:left;color:var(--text-2);white-space:nowrap">${esc(h)}</th>`).join('')}</tr></thead>
        <tbody>${preview.map(r=>`<tr style="border-top:1px solid var(--border-2)">${headers.map(h=>`<td style="padding:5px 8px;white-space:nowrap;overflow:hidden;max-width:150px;text-overflow:ellipsis">${esc(r[h]||'')}</td>`).join('')}</tr>`).join('')}</tbody>
      </table>
    </div>`;
}

function normalizePhone(phone) {
  if (!phone) return '';
  return phone.replace(/[\s\-\(\)\.]/g,'').replace(/^\+30/,'').replace(/^0030/,'');
}

function parseGreekDate(str) {
  if (!str) return null;
  const m = str.match(/(\d{1,2})[\/\-\.](\d{1,2})[\/\-\.](\d{2,4})/);
  if (!m) return null;
  const y = m[3].length===2 ? '20'+m[3] : m[3];
  return `${y}-${m[2].padStart(2,'0')}-${m[1].padStart(2,'0')}`;
}

function parseDateTime(dateStr, timeStr) {
  const d = parseGreekDate(dateStr);
  if (!d) return null;
  const t = timeStr ? timeStr.replace('.',':').substring(0,5) : '09:00';
  return `${d}T${t}:00`;
}

function mapApptStatus(s) {
  const map = {'ολοκληρώθηκε':'completed','επιβεβαιωμένο':'confirmed','ακυρώθηκε':'cancelled','εκκρεμεί':'pending','pending':'pending','confirmed':'confirmed','completed':'completed','cancelled':'cancelled'};
  return map[(s||'').toLowerCase()]||'confirmed';
}

// ── GLOBAL SEARCH ──
let _searchTimeout = null;

// Latin to Greek transliteration map
function latinToGreek(str) {
  const map = {
    'a':'α','b':'β','g':'γ','d':'δ','e':'ε','z':'ζ','h':'η','th':'θ',
    'i':'ι','k':'κ','l':'λ','m':'μ','n':'ν','x':'ξ','o':'ο','p':'π',
    'r':'ρ','s':'σ','t':'τ','u':'υ','f':'φ','ch':'χ','ps':'ψ','w':'ω',
    'c':'κ','y':'υ','v':'β','j':'γ',
    // Common name patterns
    'maria':'μαρία','mara':'μαρα','anna':'αννα','elena':'ελενα','eleni':'ελένη',
    'georgia':'γεωργία','katerina':'κατερίνα','sophia':'σοφία','sofia':'σοφία',
    'nikos':'νίκος','kostas':'κωστας','giorgos':'γιώργος','yannis':'γιάννης',
    'ioannis':'ιωάννης','stavros':'σταύρος','petros':'πέτρος','takis':'τάκης',
    'lina':'λίνα','dina':'ντίνα','tina':'τίνα','nina':'νίνα',
    'anthi':'ανθή','despina':'δέσποινα','vasiliki':'βασιλική','niki':'νίκη',
    'konstantina':'κωνσταντίνα','christina':'χριστίνα','angeliki':'αγγελική',
    'papado':'παπαδο','panou':'πάνου','kosta':'κωστα','theod':'θεοδ',
  };
  let result = str.toLowerCase();
  // Try full word matches first
  Object.entries(map).sort((a,b)=>b[0].length-a[0].length).forEach(([lat,gr]) => {
    result = result.replace(new RegExp(lat, 'gi'), gr);
  });
  return result;
}

// Greek to Latin transliteration (reverse)
function greekToLatin(str) {
  const map = {'α':'a','β':'v','γ':'g','δ':'d','ε':'e','ζ':'z','η':'i','θ':'th','ι':'i','κ':'k','λ':'l','μ':'m','ν':'n','ξ':'x','ο':'o','π':'p','ρ':'r','σ':'s','ς':'s','τ':'t','υ':'y','φ':'f','χ':'ch','ψ':'ps','ω':'o','ά':'a','έ':'e','ή':'i','ί':'i','ό':'o','ύ':'y','ώ':'o','ϊ':'i','ϋ':'y','ΐ':'i','ΰ':'y'};
  return str.toLowerCase().split('').map(c=>map[c]||c).join('');
}

async function globalSearch(q) {
  if (!q || q.length < 2) { S.globalResults = []; render(); return; }
  const cid = clinicId();
  if (!cid) return;
  const results = [];

  // Build search variants
  const qLower = q.toLowerCase();
  const qGreek = latinToGreek(qLower);
  const qLatin = greekToLatin(qLower);

  // Build OR filter for all variants
  const buildFilter = (field) => {
    const variants = [...new Set([qLower, qGreek, qLatin])].filter(v=>v.length>1);
    return variants.map(v=>`${field}.ilike.%${v}%`).join(',');
  };

  // Search patients - name, phone, email
  const {data:pts} = await sb.from('patients').select('id,full_name,phone,status,email')
    .eq('clinic_id',cid)
    .or(`full_name.ilike.%${qLower}%,full_name.ilike.%${qGreek}%,full_name.ilike.%${qLatin}%,phone.ilike.%${qLower}%,email.ilike.%${qLower}%`)
    .limit(6);
  (pts||[]).forEach(p => results.push({
    type:'patient', id:p.id,
    title:p.full_name,
    sub:p.phone||p.email||'',
    tag:(STATUS_PAT[p.status]&&STATUS_PAT[p.status].l)||p.status||'—'
  }));

  // Search appointments by service name
  const {data:apts} = await sb.from('appointments')
    .select('id,patient_id,service_name,start_time,status,patients(full_name)')
    .eq('clinic_id',cid)
    .or(`service_name.ilike.%${qLower}%,service_name.ilike.%${qGreek}%`)
    .limit(3);
  (apts||[]).forEach(a => results.push({
    type:'appointment', id:a.patient_id||a.id,
    title:(a.patients&&a.patients.full_name)||a.service_name||'—',
    sub:a.service_name+' · '+fmtDt(a.start_time),
    tag:(STATUS_APPT[a.status]&&STATUS_APPT[a.status].l)||a.status
  }));

  // Remove duplicates by id
  const seen = new Set();
  S.globalResults = results.filter(r => {
    const key = r.type+r.id;
    if (seen.has(key)) return false;
    seen.add(key); return true;
  });
  render();
}

// ── VOICE AGENT ──
let _recognition = null;
let _voiceProcessing = false;

function startVoiceAgent() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    alert('Ο browser σου δεν υποστηρίζει φωνητική αναγνώριση. Χρησιμοποίησε Chrome.');
    return;
  }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  _recognition = new SR();
  _recognition.lang = 'el-GR';
  _recognition.continuous = false;
  _recognition.interimResults = false;
  _recognition.onresult = (e) => {
    const text = e.results[0][0].transcript;
    S.voiceActive = false;
    S.voiceResult = '🎤 "' + text + '" — Επεξεργασία...';
    render();
    processVoiceCommand(text);
  };
  _recognition.onerror = () => { S.voiceActive=false; S.voiceResult='❌ Δεν ακούστηκε τίποτα. Δοκίμασε ξανά.'; render(); };
  _recognition.onend = () => { if(S.voiceActive) { S.voiceActive=false; render(); } };
  S.voiceActive = true;
  render();
  _recognition.start();
}

function stopVoiceAgent() {
  if (_recognition) _recognition.stop();
  S.voiceActive = false;
  render();
}

async function processVoiceCommand(text) {
  const t = text.toLowerCase().trim();
  // Navigation commands
  if (t.includes('dashboard') || t.includes('αρχική')) { S.page='dashboard'; S.voiceResult='✓ Πήγα στο Dashboard'; await loadPageData(); render(); return; }
  if (t.includes('ασθεν') || t.includes('πελάτ')) { S.page='patients'; S.voiceResult='✓ Άνοιξα τους Ασθενείς'; await loadPageData(); render(); return; }
  if (t.includes('ραντεβού') || t.includes('προγραμμα')) { S.page='appointments'; S.voiceResult='✓ Άνοιξα τα Ραντεβού'; await loadPageData(); render(); return; }
  if (t.includes('calendar') || t.includes('πρόγραμμα') || t.includes('ημερολόγιο')) { S.page='calendar'; S.voiceResult='✓ Άνοιξα το Πρόγραμμα'; await loadPageData(); render(); return; }
  if (t.includes('pipeline') || t.includes('leads')) { S.page='pipeline'; S.voiceResult='✓ Άνοιξα το Pipeline'; await loadPageData(); render(); return; }
  if (t.includes('ρυθμίσεις') || t.includes('settings')) { S.page='settings'; S.voiceResult='✓ Άνοιξα τις Ρυθμίσεις'; render(); return; }

  // New appointment
  if ((t.includes('νέο') || t.includes('καινούργιο') || t.includes('προσθ')) && t.includes('ραντεβού')) {
    S.modal='new-appt'; S.voiceResult='✓ Άνοιξα φόρμα νέου ραντεβού'; render(); return;
  }
  // New patient
  if ((t.includes('νέο') || t.includes('καινούργιο') || t.includes('προσθ')) && (t.includes('ασθεν') || t.includes('πελάτ'))) {
    S.modal='new-patient'; S.voiceResult='✓ Άνοιξα φόρμα νέου ασθενή'; render(); return;
  }

  // Search patient by name
  const searchTriggers = ['βρες', 'ψάξε', 'αναζήτηση', 'βρείτε', 'άνοιξε'];
  const hasTrigger = searchTriggers.some(tr => t.includes(tr));
  if (hasTrigger) {
    // Extract name after trigger word
    let query = t;
    searchTriggers.forEach(tr => { query = query.replace(tr,''); });
    query = query.replace(/ασθεν[ή|η|α]?|πελάτ[η|α]?/g,'').trim();
    if (query.length > 1) {
      S.voiceResult='🔍 Αναζητώ "' + query + '"...';
      render();
      S.globalSearch = query;
      // Also try greek transliteration
      const qGreek = latinToGreek(query);
      await globalSearch(qGreek.length > 1 ? qGreek : query);
      // If found single patient, open it
      if (S.globalResults&&S.globalResults.length===1&&S.globalResults[0].type==='patient') {
        await loadPatientDetail(S.globalResults[0].id);
        S.voiceResult='✓ Βρήκα και άνοιξα: ' + S.globalResults[0].title;
        S.globalSearch=''; S.globalResults=[];
      } else if (S.globalResults&&S.globalResults.length>0) {
        S.voiceResult='✓ Βρήκα ' + S.globalResults.length + ' αποτελέσματα για "' + query + '"';
      } else {
        S.voiceResult='❌ Δεν βρέθηκε "' + query + '"';
      }
      render(); return;
    }
  }

  // Status change commands
  if (t.includes('ολοκλήρωσε') || t.includes('ολοκληρώθηκε')) {
    S.voiceResult='💡 Πες τον ασθενή + "ολοκλήρωσε ραντεβού"'; render(); return;
  }

  // Today's schedule
  if (t.includes('σήμερα') || t.includes('πρόγραμμα σήμερα')) {
    const today = new Date().toDateString();
    const todayApts = (S.appointments||[]).filter(a=>new Date(a.start_time).toDateString()===today);
    S.voiceResult=`📅 Σήμερα έχεις ${todayApts.length} ραντεβού${todayApts.length?': '+todayApts.map(a=>(a.patients&&a.patients.full_name||'—')+' '+new Date(a.start_time).toLocaleTimeString('el-GR',{hour:'2-digit',minute:'2-digit'})).join(', '):''}`;
    render(); return;
  }

  // Fallback
  S.voiceResult='❓ Δεν κατάλαβα "' + text + '". Πες: "βρες [όνομα]", "νέο ραντεβού", "άνοιξε ασθενείς"';
  render();
}

